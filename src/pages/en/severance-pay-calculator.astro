---
import CalcolatoreLayout from '../../layouts/CalcolatoreLayout.astro';
import TFR from '../../components/calcolatori/TFR';
import { SITE } from '../../config';
import { canonicalURL } from '../../lib/seo';

const lang = 'en' as const;
const title = "TFR Severance Pay Calculator Italy 2026: Net Payout";
const description = "Calculate your Italian TFR severance (trattamento di fine rapporto). Enter RAL and years of service to see gross accrual, separate taxation, and net payout.";
const canonical = canonicalURL('/en/severance-pay-calculator/');

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'TFR Calculator', url: canonical },
];
---

<CalcolatoreLayout
  title={title}
  description={description}
  calculatorName="TFR Calculator"
  breadcrumbs={breadcrumbs}
  canonical={canonical}
  lang={lang}
>
  <TFR client:load lang={lang} />
</CalcolatoreLayout>
