          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">61 years</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">4.781%</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;4,781/year</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">62 years</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">4.940%</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;4,940/year</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">63 years</td>
