            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Law 214/2011</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Early retirement &mdash; women</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">41 years and 10 months contributions</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Law 214/2011</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Contribution ceiling 2026 (<em>massimale contributivo</em>)</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">~&euro;120,607</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">INPS (ISTAT-adjusted)</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Pension fund deductibility</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Up to &euro;5,164.57/year</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">D.Lgs. 252/2005</td>
