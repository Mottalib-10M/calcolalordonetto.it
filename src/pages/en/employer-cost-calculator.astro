            <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">TFR</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">INAIL</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Total cost</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Multipl.</th>
          </tr>
        </thead>
