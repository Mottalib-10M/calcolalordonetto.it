          </tr>
          <tr>
            <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">30,000 &euro;</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">7,143 &euro;</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">2,211 &euro;</td>
