            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">2,948 &euro;</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">160 &euro;</td>
            <td class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">52,632 &euro;</td>
