            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">1,843 &euro;</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">100 &euro;</td>
            <td class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">32,896 &euro;</td>
