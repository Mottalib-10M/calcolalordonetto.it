            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">700 - 1,050 &euro;</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">Construction (Edilizia)</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">4.0% - 6.0%</td>
            <td class="px-4 py-3 text-right text-gray-600 dark:text-gray-400">1,400 - 2,100 &euro;</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">Freight Transport (Trasporto merci)</td>
