---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="The requested page does not exist. Use our free Italian salary and tax calculators or return to the homepage." noindex={true} lang="en">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:py-24 text-center">
    <p class="text-8xl font-bold text-brand">404</p>
    <h1 class="mt-4 text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
      Page Not Found
    </h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">
      The page you are looking for does not exist or has been moved.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/en/"
        class="inline-flex items-center gap-2 rounded-lg bg-brand px-5 py-2.5 text-sm font-medium text-white shadow hover:bg-red-700 transition-colors"
      >
        Net Salary Calculator
      </a>
      <a
        href="/en/calculators/"
        class="inline-flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
      >
        All Calculators
      </a>
    </div>

    <!-- Popular calculators -->
    <div class="mt-16 text-left">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
        Popular Calculators
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/en/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">Net Salary Calculator</p>
        </a>
        <a href="/en/gross-salary-calculator/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">Gross Salary Calculator</p>
        </a>
        <a href="/en/irpef-tax-calculator/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">IRPEF Tax Calculator</p>
        </a>
        <a href="/en/payslip-calculator/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">Payslip Calculator</p>
        </a>
        <a href="/en/severance-pay-calculator/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">Severance Pay Calculator</p>
        </a>
        <a href="/en/flat-rate-regime-calculator/" class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 hover:border-brand transition-colors">
          <p class="font-medium text-gray-900 dark:text-white text-sm">Flat Rate Regime Calculator</p>
        </a>
      </div>
    </div>

    <!-- Report broken link -->
    <p class="mt-12 text-sm text-gray-500 dark:text-gray-400">
      Found a broken link?<br />
      <a href="mailto:contact@calcolalordonetto.it" class="text-brand hover:underline">contact@calcolalordonetto.it</a>
    </p>
  </div>
</Layout>
