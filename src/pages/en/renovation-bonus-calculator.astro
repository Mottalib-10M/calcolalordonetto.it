---
import CalcolatoreLayout from '../../layouts/CalcolatoreLayout.astro';
import BonusRistrutturazione from '../../components/calcolatori/BonusRistrutturazione';
import { SITE } from '../../config';
import { canonicalURL } from '../../lib/seo';

const lang = 'en' as const;
const title = "Renovation Bonus Calculator Italy 2026: Tax Deduction";
const description = "Calculate your Italian renovation tax deduction (bonus ristrutturazione). See yearly savings for 50% and 36% bonus rates spread over 10 years of tax returns.";
const canonical = canonicalURL('/en/renovation-bonus-calculator/');

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'Renovation Bonus Calculator', url: canonical },
];
---

<CalcolatoreLayout
  title={title}
  description={description}
  calculatorName="Renovation Bonus Calculator"
  breadcrumbs={breadcrumbs}
  canonical={canonical}
  lang={lang}
>
  <BonusRistrutturazione client:load lang={lang} />
</CalcolatoreLayout>
