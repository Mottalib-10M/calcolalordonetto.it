            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">~&euro;2,600/month</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">ISTAT 2024</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">Portfolio stamp duty (imposta di bollo)</td>
