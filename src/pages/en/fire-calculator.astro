      </table>
    </div>
    <div class="prose prose-gray dark:prose-invert max-w-none mt-6">
      <h3 class="text-xl font-semibold text-gray-900 dark:text-white mt-4 mb-3">
        FIRE number benchmarks by monthly spending
      </h3>
      <p>
        The table below shows FIRE numbers for different monthly expense levels, calculated at both the standard
        4% withdrawal rate and a more conservative 3.5% rate suitable for the Italian tax environment:
      </p>
    </div>
    <div class="overflow-x-auto mt-4">
      <table class="min-w-full text-sm border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">Monthly Expenses</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">Annual Expenses</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">FIRE Number (4%)</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">FIRE Number (3.5%)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-900">
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;1,200</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;14,400</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;360,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;411,429</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;1,500</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;18,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;450,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;514,286</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;2,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;24,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;600,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;685,714</td>
          </tr>
          <tr>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;2,500</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;30,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;750,000</td>
            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">&euro;857,143</td>
          </tr>
