---
import Layout from '../../../layouts/Layout.astro';
import { SITE } from '../../../config';
import { calcolaLordoDaNetto, calcolaStipendio, calcolaIRPEF } from '../../../lib/irpef-engine';
import { regioni } from '../../../data/regioni';
import { breadcrumbSchema, faqSchema } from '../../../lib/seo';
import { formatCurrency, formatRate, formatNumber, formatPercent } from '../../../lib/format';

export function getStaticPaths() {
  const amounts = [
    1000, 1200, 1300, 1400, 1500, 1600, 1700, 1800,
    2000, 2200, 2500, 2800, 3000, 3500, 4000, 5000,
  ];

  return amounts.map((netto) => ({
    params: { slug: `${netto}-euro` },
    props: { nettoTarget: netto },
  }));
}

interface Props {
  nettoTarget: number;
}

const { nettoTarget } = Astro.props;
const { slug } = Astro.params;

const defaultRegione = 'LOM';

// Main calculation
const { ral: ralDefault, risultato: defaultResult } = calcolaLordoDaNetto(nettoTarget, defaultRegione);

// Calculate for all regions
const regionResults = regioni.map((r) => {
  const { ral, risultato } = calcolaLordoDaNetto(nettoTarget, r.codice);
  return {
    codice: r.codice,
    nome: r.nome,
    ral,
    nettoMensile: risultato.nettoMensile,
    addizionaleRegionale: risultato.addizionaleRegionale,
    aliquotaMedia: risultato.aliquotaMedia,
  };
}).sort((a, b) => a.ral - b.ral);

// Detailed breakdown for default scenario
const dettaglio = calcolaStipendio({ ral: ralDefault, regione: defaultRegione });
const irpefDetail = calcolaIRPEF(dettaglio.imponibileFiscale - dettaglio.cuneoFiscaleSommaEsente);

// Format helpers
const fmtCur = (v: number) => formatCurrency(v, 'en');
const fmtCurRound = (v: number) => v.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
const fmtPct = (v: number) => formatRate(v, 'en');

// Adjacent amounts for navigation
const allAmounts = [1000, 1200, 1300, 1400, 1500, 1600, 1700, 1800, 2000, 2200, 2500, 2800, 3000, 3500, 4000, 5000];
const currentIndex = allAmounts.indexOf(nettoTarget);
const prevAmount = currentIndex > 0 ? allAmounts[currentIndex - 1] : null;
const nextAmount = currentIndex < allAmounts.length - 1 ? allAmounts[currentIndex + 1] : null;

// Market context based on salary level
function getMarketContext(netto: number): { livello: string; settori: string; contesto: string } {
  if (netto <= 1200) return {
    livello: 'entry-level',
    settori: 'retail, hospitality, personal services, customer support',
    contesto: 'This salary level is typical of junior or part-time positions in the service sector in Italy. According to ISTAT data, approximately 25% of Italian employees earn a net salary below €1,200 per month.',
  };
  if (netto <= 1500) return {
    livello: 'lower-middle',
    settori: 'administrative staff, skilled workers, organized retail, logistics',
    contesto: 'This is the most common salary range in Italy. According to ISTAT, the median net salary for Italian employees is around €1,400 per month. This level is typical for employees with 2–5 years of experience.',
  };
  if (netto <= 1800) return {
    livello: 'middle',
    settori: 'manufacturing, professional services, public administration, junior banking',
    contesto: 'A salary in line with the national average for full-time employees in Italy. This level is typical of profiles with intermediate experience (5–10 years) or specialized roles in the industrial and service sectors.',
  };
  if (netto <= 2200) return {
    livello: 'upper-middle',
    settori: 'IT and technology, consulting, engineering, banking and insurance, pharmaceuticals',
    contesto: 'Above the Italian national average. This salary level is typical of qualified professionals with significant experience, middle managers, or specialized technical roles in Northern Italy. However, the higher cost of living in major Northern cities should be considered.',
  };
  if (netto <= 3000) return {
    livello: 'high',
    settori: 'management, senior IT, strategic consulting, finance, SME executives, medical specialists',
    contesto: 'Well above the Italian national average, this salary level applies to fewer than 10% of Italian employees. It is typical of managerial roles, senior professionals in the technology and financial sectors, or middle managers with significant responsibilities.',
  };
  return {
    livello: 'very high',
    settori: 'top management, corporate leadership, executive consulting, structured finance, chief physicians',
    contesto: 'In the highest bracket of employee compensation in Italy, this level applies to fewer than 3% of workers. It is typical of executives, C-level positions in medium-to-large companies, or top-tier professionals in high-paying sectors.',
  };
}

const market = getMarketContext(nettoTarget);

// FAQs
const faqs = [
  {
    question: `What gross salary do you need to earn €${fmtCurRound(nettoTarget)} net per month?`,
    answer: `To take home approximately €${fmtCurRound(nettoTarget)} net per month in Italy, you need a gross annual salary (RAL) of about €${fmtCurRound(ralDefault)}, based on 13 pay periods, a permanent employment contract in Lombardy, with no dependent family members.`,
  },
  {
    question: `Is €${fmtCurRound(nettoTarget)} net per month a good salary in Italy?`,
    answer: `A net salary of €${fmtCurRound(nettoTarget)} per month is at a ${market.livello} level compared to the Italian national average. The median net salary in Italy is approximately €1,400 per month (ISTAT data). Purchasing power also depends on the city of residence.`,
  },
  {
    question: `Does the required gross salary change by region?`,
    answer: `Yes, regional IRPEF surcharges vary significantly across Italian regions. To earn €${fmtCurRound(nettoTarget)} net, the required gross salary (RAL) can differ by several hundred euros between the most and least tax-favorable regions. Regions with the lowest surcharges are generally Friuli-Venezia Giulia, Sardinia, and Veneto.`,
  },
  {
    question: `How is net salary calculated from gross in Italy?`,
    answer: `From the gross salary, the following are deducted: INPS social security contributions (9.19%), IRPEF income tax calculated on progressive brackets (23%, 33%, 43%), and regional and municipal surcharges. Then employment deductions, the tax wedge, and any supplementary allowance (formerly known as "Bonus Renzi") are added back.`,
  },
  {
    question: `Does monthly net pay change with 14 pay periods?`,
    answer: `With 14 pay periods, the gross annual salary (RAL) remains the same, but the annual net is divided by 14 instead of 13, so each monthly payment is lower (about 7% less per paycheck), offset by the two additional payments. The total annual net remains essentially unchanged.`,
  },
];

// SEO
const title = `€${fmtCurRound(nettoTarget)} Net per Month: Required Gross Salary in Italy ${SITE.annoFiscale}`;
const description = `To earn €${fmtCurRound(nettoTarget)} net monthly you need about €${fmtCurRound(ralDefault)} gross (RAL). Full ${SITE.annoFiscale} breakdown: IRPEF, INPS, and regional taxes.`;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'Monthly Salary', url: `${SITE.url}/en/monthly-salary/` },
  { name: `€${fmtCurRound(nettoTarget)}`, url: `${SITE.url}/en/monthly-salary/${slug}/` },
];

const schemaString = JSON.stringify([
  breadcrumbSchema(breadcrumbs),
  faqSchema(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: `${SITE.url}/en/monthly-salary/${slug}/`,
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', name: SITE.name, url: `${SITE.url}/` },
    dateModified: '2026-01-15',
  },
]);
---

<Layout
  title={title}
  description={description}
  schema={schemaString}
  lang="en"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="py-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center gap-1.5">
            {index > 0 && (
              <svg class="h-3.5 w-3.5 flex-shrink-0 text-gray-400 dark:text-gray-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            )}
            {index < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-brand transition-colors">
                {crumb.name}
              </a>
            ) : (
              <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">
                {crumb.name}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- H1 Hero -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 dark:from-gray-800 dark:to-gray-900 px-6 py-10 sm:px-10 sm:py-14 mb-10">
      <div class="relative z-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
          &euro;{fmtCurRound(nettoTarget)} Net Monthly Salary: What Gross Salary Do You Need in {SITE.annoFiscale}?
        </h1>
        <p class="mt-4 text-lg text-gray-300 max-w-2xl">
          To earn <strong class="text-white">&euro;{fmtCurRound(nettoTarget)} net per month</strong> you need approximately <strong class="text-white">&euro;{fmtCurRound(ralDefault)} RAL</strong> (based on 13 pay periods).
        </p>
        <div class="mt-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-green-500/10 px-3 py-1 text-xs font-medium text-green-400 ring-1 ring-green-500/30">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
            </svg>
            Updated {SITE.annoFiscale}
          </span>
        </div>
        <div class="mt-8">
          <a
            href={`/en/gross-salary-calculator?netto=${nettoTarget}`}
            class="inline-flex items-center gap-2 rounded-lg bg-brand px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-dark transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            Calculate your case
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-brand"></div>
        <div class="absolute -left-10 -bottom-10 h-60 w-60 rounded-full bg-brand"></div>
      </div>
    </section>

    <!-- H2: Required Gross Salary by Region -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Required Gross Salary by Region
      </h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Regional IRPEF surcharges significantly affect your net pay. Here is the gross salary (RAL) required to take home approximately &euro;{fmtCurRound(nettoTarget)} net per month in each Italian region.
      </p>
      <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">Region</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Required RAL</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Monthly Net</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Regional Surcharge</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Average Rate</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
            {regionResults.map((r) => (
              <tr class:list={[
                'transition-colors',
                r.codice === defaultRegione
                  ? 'bg-brand/5 dark:bg-brand/10'
                  : 'hover:bg-gray-50 dark:hover:bg-gray-800/30',
              ]}>
                <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">
                  {r.nome}
                  {r.codice === defaultRegione && (
                    <span class="ml-1.5 text-xs text-brand font-normal">(ref.)</span>
                  )}
                </td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCurRound(r.ral)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCur(r.nettoMensile)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCur(r.addizionaleRegionale)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtPct(r.aliquotaMedia)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
        * Calculations based on 13 pay periods, permanent employment contract, no dependent family members. National average municipal surcharge applied.
      </p>
    </section>

    <!-- H2: Tax Breakdown -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Tax Breakdown with RAL of &euro;{fmtCurRound(ralDefault)}
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Left column: breakdown -->
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
          <div class="bg-gray-50 dark:bg-gray-800/50 px-5 py-3 border-b border-gray-200 dark:border-gray-800">
            <h3 class="font-semibold text-gray-900 dark:text-white">From Gross to Net</h3>
          </div>
          <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">RAL (Gross Annual)</span>
              <span class="font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.ral)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">INPS Contributions (9.19%)</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.contributiINPS)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3 bg-gray-50/50 dark:bg-gray-800/25">
              <span class="text-gray-600 dark:text-gray-400">Taxable Income</span>
              <span class="font-medium text-gray-900 dark:text-white">{fmtCur(dettaglio.imponibileFiscale)} &euro;</span>
            </div>
            {dettaglio.cuneoFiscaleSommaEsente > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Tax Wedge (exempt amount)</span>
                <span class="text-green-600 dark:text-green-400">-{fmtCur(dettaglio.cuneoFiscaleSommaEsente)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Gross IRPEF</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.irpefLorda)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Employment Deduction</span>
              <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.detrazioneLavoroDipendente)} &euro;</span>
            </div>
            {dettaglio.cuneoFiscaleDetrazione > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Tax Wedge (deduction)</span>
                <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.cuneoFiscaleDetrazione)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Net IRPEF</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.irpefNetta)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Regional Surcharge</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.addizionaleRegionale)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Municipal Surcharge</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.addizionaleComunale)} &euro;</span>
            </div>
            {dettaglio.trattamentoIntegrativo > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Supplementary Allowance</span>
                <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.trattamentoIntegrativo)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-4 bg-gray-900 dark:bg-gray-800">
              <span class="font-semibold text-white">Annual Net</span>
              <span class="font-bold text-white text-lg">{fmtCur(dettaglio.nettoAnnuo)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-4 bg-brand/10 dark:bg-brand/20">
              <span class="font-semibold text-brand">Monthly Net (x{dettaglio.mensilita})</span>
              <span class="font-bold text-brand text-lg">{fmtCur(dettaglio.nettoMensile)} &euro;</span>
            </div>
          </div>
        </div>

        <!-- Right column: IRPEF brackets and summary -->
        <div class="space-y-6">
          <!-- Applied IRPEF Tax Brackets -->
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
            <div class="bg-gray-50 dark:bg-gray-800/50 px-5 py-3 border-b border-gray-200 dark:border-gray-800">
              <h3 class="font-semibold text-gray-900 dark:text-white">Applied IRPEF Tax Brackets</h3>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-gray-800">
              {irpefDetail.dettaglioScaglioni.map((s) => (
                <div class="flex justify-between px-5 py-3">
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">{s.scaglione}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Rate {fmtPct(s.aliquota)}</p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">{fmtCur(s.impostaScaglione)} &euro;</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">on {fmtCur(s.imponibileInScaglione)} &euro;</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Rate Summary -->
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Rate Summary</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Average effective rate</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.aliquotaMedia)}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Marginal rate</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.aliquotaMarginale)}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Total tax wedge</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.cuneoFiscaleTotale)}</span>
              </div>
              <hr class="border-gray-200 dark:border-gray-700" />
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Employer cost</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.costoAzienda)} &euro;</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Annual TFR accrued</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.tfrAnnuo)} &euro;</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- H2: Labor Market Comparison -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Labor Market Comparison
      </h2>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand/10 dark:bg-brand/20 flex items-center justify-center">
            <svg class="h-5 w-5 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M1 2.75A.75.75 0 0 1 1.75 2h16.5a.75.75 0 0 1 0 1.5H18v8.75A2.75 2.75 0 0 1 15.25 15h-1.072l.798 3.06a.75.75 0 0 1-1.452.38L13.41 18H6.59l-.114.44a.75.75 0 0 1-1.452-.38L5.822 15H4.75A2.75 2.75 0 0 1 2 12.25V3.5h-.25A.75.75 0 0 1 1 2.75Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">
              Salary level: <span class="text-brand">{market.livello}</span>
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
              {market.contesto}
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              <strong class="text-gray-900 dark:text-white">Typical sectors:</strong> {market.settori}.
            </p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Required RAL</p>
            <p class="text-xl font-bold text-gray-900 dark:text-white">{fmtCurRound(ralDefault)} &euro;</p>
          </div>
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Monthly gross</p>
            <p class="text-xl font-bold text-gray-900 dark:text-white">{fmtCur(dettaglio.ralMensile)} &euro;</p>
          </div>
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Monthly net</p>
            <p class="text-xl font-bold text-brand">{fmtCur(dettaglio.nettoMensile)} &euro;</p>
          </div>
        </div>

        <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
          Sources: analysis based on <a href="https://www.istat.it" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">ISTAT</a> and <a href="https://www.inps.it" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">INPS</a> data.
          Labor market references are indicative and may vary based on experience, sector, company size, and geographic area.
        </p>
      </div>
    </section>

    <!-- H2: FAQ -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
            <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-semibold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              {faq.question}
              <svg class="h-5 w-5 flex-shrink-0 text-gray-400 group-open:rotate-180 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Adjacent links -->
    <nav aria-label="Related monthly amounts" class="mb-16 flex flex-col sm:flex-row gap-4">
      {prevAmount && (
        <a
          href={`/en/monthly-salary/${prevAmount}-euro/`}
          class="flex-1 group flex items-center gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-brand dark:hover:border-brand transition-colors"
        >
          <svg class="h-5 w-5 text-gray-400 group-hover:text-brand transition-colors" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
          </svg>
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Previous amount</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-brand transition-colors">
              &euro;{fmtCurRound(prevAmount)} net/month
            </p>
          </div>
        </a>
      )}
      {nextAmount && (
        <a
          href={`/en/monthly-salary/${nextAmount}-euro/`}
          class="flex-1 group flex items-center justify-end gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-brand dark:hover:border-brand transition-colors text-right"
        >
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Next amount</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-brand transition-colors">
              &euro;{fmtCurRound(nextAmount)} net/month
            </p>
          </div>
          <svg class="h-5 w-5 text-gray-400 group-hover:text-brand transition-colors" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </a>
      )}
    </nav>
  </div>
</Layout>
