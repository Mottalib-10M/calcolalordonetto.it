---
import CalcolatoreLayout from '../../layouts/CalcolatoreLayout.astro';
import Mutuo from '../../components/calcolatori/Mutuo';
import { SITE } from '../../config';
import { canonicalURL } from '../../lib/seo';

const lang = 'en' as const;
const title = "Mortgage Calculator Italy 2026: Monthly Payment & Rates";
const description = "Calculate your Italian mortgage monthly payment, total interest, and full amortization schedule. Compare fixed vs variable rates and find affordable amounts.";
const canonical = canonicalURL('/en/mortgage-calculator/');

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'Mortgage Calculator', url: canonical },
];
---

<CalcolatoreLayout
  title={title}
  description={description}
  calculatorName="Mortgage Calculator"
  breadcrumbs={breadcrumbs}
  canonical={canonical}
  lang={lang}
>
  <Mutuo client:load lang={lang} />
</CalcolatoreLayout>
