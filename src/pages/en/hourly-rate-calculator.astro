---
import CalcolatoreLayout from '../../layouts/CalcolatoreLayout.astro';
import PagaOraria from '../../components/calcolatori/PagaOraria';
import { SITE } from '../../config';
import { canonicalURL } from '../../lib/seo';

const lang = 'en' as const;
const title = "Hourly Rate Calculator Italy 2026: Gross and Net Pay";
const description = "Convert your gross annual salary (RAL) into gross and net hourly rate. Factors in weekly hours, CCNL contract type, and 2026 Italian tax rules automatically.";
const canonical = canonicalURL('/en/hourly-rate-calculator/');

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'Hourly Rate Calculator', url: canonical },
];
---

<CalcolatoreLayout
  title={title}
  description={description}
  calculatorName="Hourly Rate Calculator"
  breadcrumbs={breadcrumbs}
  canonical={canonical}
  lang={lang}
>
  <PagaOraria client:load lang={lang} />
</CalcolatoreLayout>
