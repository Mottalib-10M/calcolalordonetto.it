        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        <tr>
          <td class="py-3 pr-4 text-gray-900 dark:text-gray-100 font-medium">Tax exemption</td>
          <td class="py-3 px-4 text-gray-900 dark:text-gray-100">70% (only 30% taxed)</td>
