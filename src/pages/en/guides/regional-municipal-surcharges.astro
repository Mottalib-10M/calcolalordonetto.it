          <th class="py-3 px-4 text-center font-semibold text-gray-700 dark:text-gray-300">Municipal rate</th>
          <th class="py-3 px-4 text-center font-semibold text-gray-700 dark:text-gray-300">Municipal surcharge</th>
          <th class="py-3 pl-4 text-right font-semibold text-gray-700 dark:text-gray-300">Total surcharges</th>
        </tr>
      </thead>
