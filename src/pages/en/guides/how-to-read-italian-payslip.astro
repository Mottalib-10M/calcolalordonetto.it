---
import GuidaLayout from '../../../layouts/GuidaLayout.astro';
import FAQFisarmonica from '../../../components/ui/FAQFisarmonica.astro';
import { SITE } from '../../../config';

const lang = 'en' as const;
const title = "How to Read an Italian Payslip: Busta Paga Line by Line";
const description = "Understand every line of your Italian payslip (busta paga). Header, gross pay, INPS contributions, IRPEF withholding, deductions, bonuses, and net pay guide.";

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/en/` },
  { name: 'Guides', url: `${SITE.url}/en/guides/` },
  { name: 'How to Read an Italian Payslip', url: `${SITE.url}/en/guides/how-to-read-italian-payslip/` },
];

const faqs = [
  {
    question: 'What is the difference between busta paga, cedolino, and prospetto paga?',
    answer: 'These are all names for the same document: your monthly payslip. <strong>Busta paga</strong> (literally "pay envelope") is the most common informal term. <strong>Cedolino</strong> (slip/stub) is used interchangeably, especially in the public sector. <strong>Prospetto paga</strong> is the more formal/legal term. Regardless of the name, the document must include the same mandatory information under Italian law (L. 4/1953): employer and employee data, pay period, gross pay, all deductions, and net pay.',
  },
  {
    question: 'What does "competenze" vs "trattenute" mean on my payslip?',
    answer: '<strong>Competenze</strong> (earnings/entitlements) is the left column of your payslip showing everything you have earned in the pay period: base salary (paga base/minimo tabellare), seniority increases (scatti di anzianita), overtime (straordinario), bonuses, and any other additions. <strong>Trattenute</strong> (withholdings/deductions) is the right column showing everything subtracted: INPS contributions, IRPEF, regional and municipal surcharges, union dues, and any salary advances recovered. Your net pay is competenze minus trattenute.',
  },
  {
    question: 'Why does my net pay change from month to month even though my gross salary is fixed?',
    answer: 'Several factors can cause monthly net pay to fluctuate: (1) <strong>Regional and municipal surcharges</strong> (addizionali) are typically spread across 11 months (January&ndash;November or March&ndash;November), so some months may have no surcharge deduction. (2) The <strong>trattamento integrativo</strong> or tax wedge bonus may be adjusted mid-year if HR recalculates your projected annual income. (3) <strong>TFR accrual</strong> and <strong>tredicesima/quattordicesima</strong> (13th/14th month bonuses) are accrued monthly but paid in specific months. (4) One-off events like overtime, bonuses, or salary advances affect individual months. Your annual total should match the expected calculation.',
  },
  {
    question: 'What should I do if I find an error on my payslip?',
    answer: 'If you spot an error on your busta paga, act promptly. First, document the discrepancy by comparing the payslip against your employment contract, CCNL tables, and any overtime or absence records. Then raise the issue <strong>in writing</strong> (email is sufficient) with your HR department or payroll office (ufficio paghe), requesting a formal correction. Under Italian law, the employer is obligated to issue a corrected payslip. If the error resulted in underpayment, you are entitled to receive the difference with the next pay cycle, plus interest if there is a significant delay. If your employer refuses to correct the mistake, you can file a claim with the <strong>Ispettorato Territoriale del Lavoro</strong> (ITL) or seek assistance from a trade union (sindacato). Keep in mind that the statute of limitations for payroll claims is <strong>5 years</strong> from the date of the error (Art. 2948 of the Italian Civil Code).',
  },
  {
    question: 'How long should I keep my payslips?',
    answer: 'You should keep your payslips for at least <strong>5 years</strong>, which corresponds to the statute of limitations for claiming unpaid wages and contributions under Italian law (Art. 2948 c.c.). However, many financial advisors and labour consultants recommend keeping them for <strong>10 years or more</strong>, especially for pension purposes. Your INPS contribution history (estratto conto contributivo) is built from employer filings that reference your payslips, and discrepancies may only surface decades later when you approach retirement. Payslips are also needed when applying for mortgages, filing your tax return (Modello 730 or Redditi PF), or applying for ISEE certification (for subsidized services). In 2026, most employers provide digital payslips through platforms like Zucchetti, TeamSystem, or ADP, which archive them automatically, but it is wise to download a personal copy as well.',
  },
];
