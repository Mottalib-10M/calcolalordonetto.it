---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../config';
import { calcolaLordoDaNetto, calcolaStipendio, calcolaIRPEF } from '../../lib/irpef-engine';
import { regioni } from '../../data/regioni';
import { breadcrumbSchema, faqSchema } from '../../lib/seo';

export function getStaticPaths() {
  const amounts = [
    1000, 1200, 1300, 1400, 1500, 1600, 1700, 1800,
    2000, 2200, 2500, 2800, 3000, 3500, 4000, 5000,
  ];

  return amounts.map((netto) => ({
    params: { slug: `${netto}-euro` },
    props: { nettoTarget: netto },
  }));
}

interface Props {
  nettoTarget: number;
}

const { nettoTarget } = Astro.props;
const { slug } = Astro.params;

const defaultRegione = 'LOM';

// Main calculation
const { ral: ralDefault, risultato: defaultResult } = calcolaLordoDaNetto(nettoTarget, defaultRegione);

// Calculate for all regions
const regionResults = regioni.map((r) => {
  const { ral, risultato } = calcolaLordoDaNetto(nettoTarget, r.codice);
  return {
    codice: r.codice,
    nome: r.nome,
    ral,
    nettoMensile: risultato.nettoMensile,
    addizionaleRegionale: risultato.addizionaleRegionale,
    aliquotaMedia: risultato.aliquotaMedia,
  };
}).sort((a, b) => a.ral - b.ral);

// Detailed breakdown for default scenario
const dettaglio = calcolaStipendio({ ral: ralDefault, regione: defaultRegione });
const irpefDetail = calcolaIRPEF(dettaglio.imponibileFiscale - dettaglio.cuneoFiscaleSommaEsente);

// Format helpers
const fmtCur = (v: number) => v.toLocaleString('it-IT', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fmtCurRound = (v: number) => v.toLocaleString('it-IT', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
const fmtPct = (v: number) => (v * 100).toLocaleString('it-IT', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%';

// Adjacent amounts for navigation
const allAmounts = [1000, 1200, 1300, 1400, 1500, 1600, 1700, 1800, 2000, 2200, 2500, 2800, 3000, 3500, 4000, 5000];
const currentIndex = allAmounts.indexOf(nettoTarget);
const prevAmount = currentIndex > 0 ? allAmounts[currentIndex - 1] : null;
const nextAmount = currentIndex < allAmounts.length - 1 ? allAmounts[currentIndex + 1] : null;

// Market context based on salary level
function getMarketContext(netto: number): { livello: string; settori: string; contesto: string } {
  if (netto <= 1200) return {
    livello: 'entry-level',
    settori: 'commercio, ristorazione, servizi alla persona, assistenza clienti',
    contesto: 'Questo livello retributivo e\' tipico di posizioni junior o part-time nel settore terziario. Secondo i dati ISTAT, circa il 25% dei lavoratori dipendenti italiani percepisce uno stipendio netto inferiore a 1.200 euro mensili.',
  };
  if (netto <= 1500) return {
    livello: 'medio-basso',
    settori: 'impiegati amministrativi, operai specializzati, commercio organizzato, logistica',
    contesto: 'Si tratta della fascia retributiva piu\' diffusa in Italia. Secondo ISTAT, lo stipendio mediano netto dei lavoratori dipendenti si colloca intorno ai 1.400 euro mensili. Questo livello e\' comune per impiegati con 2-5 anni di esperienza.',
  };
  if (netto <= 1800) return {
    livello: 'medio',
    settori: 'industria manifatturiera, servizi professionali, pubblica amministrazione, bancario junior',
    contesto: 'Una retribuzione nella media nazionale per lavoratori dipendenti a tempo pieno. Questo livello e\' tipico di profili con esperienza intermedia (5-10 anni) o di ruoli specializzati nel settore industriale e dei servizi.',
  };
  if (netto <= 2200) return {
    livello: 'medio-alto',
    settori: 'IT e tecnologia, consulenza, ingegneria, settore bancario e assicurativo, farmaceutico',
    contesto: 'Sopra la media nazionale. Questo livello retributivo e\' tipico di professionisti qualificati con esperienza significativa, quadri intermedi, o ruoli tecnici specializzati nel Nord Italia. Il costo della vita nelle grandi citta\' del Nord va tuttavia considerato.',
  };
  if (netto <= 3000) return {
    livello: 'alto',
    settori: 'management, IT senior, consulenza strategica, finanza, dirigenza PMI, medici specialisti',
    contesto: 'Ben sopra la media nazionale, questo livello retributivo riguarda meno del 10% dei lavoratori dipendenti italiani. E\' tipico di ruoli dirigenziali, professionisti senior nel settore tecnologico e finanziario, o quadri con responsabilita\' significative.',
  };
  return {
    livello: 'molto alto',
    settori: 'top management, direzione aziendale, consulenza direzionale, finanza strutturata, medici primari',
    contesto: 'Nella fascia piu\' alta delle retribuzioni da lavoro dipendente in Italia, questo livello riguarda meno del 3% dei lavoratori. E\' tipico di dirigenti, C-level in aziende medio-grandi, o professionisti di altissimo livello in settori ad alta remunerazione.',
  };
}

const market = getMarketContext(nettoTarget);

/* ── Per-amount unique content — job profiles & financial context ───────── */

const nettoProfiles: Record<number, { jobs: string; finance: string }> = {
  1000: {
    jobs: 'Uno stipendio netto di 1.000 euro al mese (circa ' + fmtCurRound(ralDefault) + ' euro di RAL) e\' tipico di contratti part-time nel commercio al dettaglio (CCNL Commercio, livello 6-7 a orario ridotto), tirocini extracurriculari retribuiti, collaborazioni nel settore della ristorazione e contratti a chiamata nel turismo stagionale. E\' anche la retribuzione di apprendisti nel primo anno in molti settori del terziario, operatori di call center con orario ridotto, e addetti alle pulizie con contratto part-time. Nelle cooperative sociali, corrisponde a educatori o animatori con contratto a 25-30 ore settimanali.',
    finance: 'Con 1.000 euro netti al mese la priorita\' assoluta e\' il controllo rigoroso delle spese fisse. L\'affitto non dovrebbe superare i 350 euro, il che rende necessaria la condivisione dell\'alloggio in quasi tutte le citta\' italiane, o la convivenza familiare. Le spese alimentari vanno contenute entro i 200-250 euro mensili, sfruttando mercati rionali, offerte settimanali e pasti preparati in casa. A questo livello di reddito e\' fondamentale verificare l\'accesso alle agevolazioni legate all\'ISEE: bonus bollette (risparmio stimato di 150-200 euro/anno), riduzione della TARI, esenzione dal ticket sanitario. Il risparmio e\' difficile ma non impossibile: anche 50 euro al mese in un conto deposito vincolato possono costruire un fondo emergenza di 600 euro in un anno, sufficiente per piccoli imprevisti.',
  },
  1200: {
    jobs: 'Un netto di 1.200 euro mensili (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' la retribuzione di commessi e cassieri full-time nel CCNL Commercio (livello 5), operai generici nell\'industria alimentare, receptionist in strutture alberghiere, assistenti di studio medico, e segretari con contratto full-time nel terziario. Nel settore pubblico, corrisponde agli operatori (ex categoria B) nelle prime classi stipendiali. E\' anche il netto tipico di OSS (operatori socio-sanitari) nelle RSA con contratto cooperativo, e di addetti alla vendita in catene di abbigliamento.',
    finance: 'Con 1.200 euro netti al mese, il budget mensile va pianificato con attenzione: circa 400-450 euro per l\'abitazione (affitto in citta\' medio-piccole o stanza in condivisione nelle grandi citta\'), 200-250 euro per alimentari, 100 euro per trasporti e utenze. Restano circa 250-300 euro per spese personali e risparmio. L\'obiettivo primario dovrebbe essere la costruzione di un fondo emergenza di almeno 3.600 euro (tre mensilita\'). Il trattamento integrativo (100 euro/mese) e\' generalmente spettante e gia\' incluso nel netto: verificarne la presenza in busta paga. Per risparmiare sulle bollette, valutare il mercato libero dell\'energia confrontando le offerte su ARERA.',
  },
  1300: {
    jobs: 'Con 1.300 euro netti al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) troviamo impiegati amministrativi junior, operai specializzati nell\'edilizia, tecnici di laboratorio di primo livello, addetti alla logistica con esperienza, e assistenti educativi nelle scuole. Nel CCNL Metalmeccanico corrisponde al livello C1 con qualche anno di anzianita\'. E\' anche lo stipendio di molti neoassunti nel settore assicurativo (impiegati di agenzia), parrucchieri ed estetiste con contratto da dipendente in saloni strutturati, e autisti di linee urbane nei primi anni di servizio.',
    finance: 'Con 1.300 euro netti al mese si raggiunge il primo livello di flessibilita\' finanziaria. Dopo aver coperto le spese essenziali (affitto 400-500 euro, alimentari 250 euro, utenze e trasporti 150 euro), restano circa 400-500 euro per spese discrezionali e risparmio. Iniziare un Piano di Accumulo Capitale (PAC) con versamenti di 100 euro/mese su un ETF azionario globale a basso costo puo\' generare circa 20.000 euro in 15 anni (con rendimento medio storico del 7%). A questo livello, la sottoscrizione del fondo pensione di categoria e\' particolarmente vantaggiosa grazie al contributo del datore di lavoro (tipicamente 1-2% della RAL), che rappresenta un beneficio netto aggiuntivo.',
  },
  1400: {
    jobs: 'Uno stipendio di 1.400 euro netti al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) corrisponde alla mediana italiana e rappresenta la retribuzione di impiegati contabili, geometri con esperienza, infermieri nei primi anni di carriera nel settore pubblico, tecnici informatici di primo livello (help desk, supporto IT), e impiegati bancari al 3° livello. Nel CCNL Commercio siamo al livello 3-4 con anzianita\', mentre nel Metalmeccanico al livello C2-C3. E\' anche lo stipendio tipico di insegnanti di scuola primaria nei primi 10 anni di ruolo e di grafici con esperienza in agenzie piccole.',
    finance: 'Con 1.400 euro netti al mese, lo stipendio si allinea alla mediana nazionale. La regola del 50/30/20 applicata a questo livello prevede: ' + fmtCurRound(1400 * 0.5) + ' euro per spese necessarie, ' + fmtCurRound(1400 * 0.3) + ' euro per desideri, ' + fmtCurRound(1400 * 0.2) + ' euro per risparmio e investimenti. Il fondo emergenza ideale e\' di ' + fmtCurRound(1400 * 4) + ' euro (4 mensilita\'). A questo livello di RAL, il cuneo fiscale prevede ancora la detrazione aggiuntiva di 1.000 euro/anno: e\' importante verificare che venga applicata correttamente in busta paga. Per l\'affitto, nelle citta\' del Nord si arriva facilmente al 40% del netto, ben oltre la soglia consigliata del 30%: valutare periferie ben collegate o citta\' satelliti.',
  },
  1500: {
    jobs: 'Un netto di 1.500 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' la retribuzione di profili come contabili senior, tecnici commerciali nel B2B, sviluppatori web junior, coordinatori di reparto nella grande distribuzione, e periti industriali con esperienza. Nel settore pubblico corrisponde ai funzionari (ex categoria D) nelle prime classi stipendiali. E\' anche lo stipendio di insegnanti di scuola secondaria con 10-15 anni di servizio, fisioterapisti in ambito privato con contratto dipendente, e addetti al marketing con 2-3 anni di esperienza.',
    finance: 'Con 1.500 euro netti al mese si supera la mediana nazionale e si entra in una fascia dove il risparmio strutturato diventa realistico. Allocando 300 euro/mese tra fondo pensione (contributo volontario deducibile) e PAC su ETF, in 20 anni si puo\' accumulare un capitale superiore ai 100.000 euro. A questo livello di RAL, attenzione alla soglia IRPEF dei 28.000 euro: se la RAL e\' appena sotto, un aumento che la porti oltre comporta il passaggio all\'aliquota marginale del 33% sull\'eccedenza. I buoni pasto (se previsti) del valore di 8 euro/giorno aggiungono circa 170 euro/mese di potere d\'acquisto netto. Per l\'abitazione, un affitto fino a 500 euro e\' sostenibile e compatibile con il risparmio: fattibile in molte citta\' del Centro-Sud e nelle periferie del Nord.',
  },
  1600: {
    jobs: 'Con 1.600 euro netti mensili (RAL circa ' + fmtCurRound(ralDefault) + ' euro) si collocano profili come analisti dati, programmatori con 2-3 anni di esperienza, specialisti HR, geometri e periti con incarichi di coordinamento, infermieri con anzianita\' nel pubblico, e impiegati direttivi nel CCNL Commercio (livello 2). Nel Metalmeccanico siamo al livello D1. E\' anche la retribuzione di giornalisti con contratto FNSI nei primi anni, project manager junior in agenzie di comunicazione, e tecnici di radiologia con esperienza.',
    finance: 'A 1.600 euro netti al mese, le opportunita\' di pianificazione finanziaria si ampliano sensibilmente. La quota risparmiabile (320 euro/mese applicando la regola del 20%) consente di combinare risparmio precauzionale e investimento: 150 euro/mese in fondo emergenza fino a raggiungere ' + fmtCurRound(1600 * 6) + ' euro (6 mensilita\'), poi ribilanciare verso un PAC diversificato. La RAL di circa ' + fmtCurRound(ralDefault) + ' euro si trova nella fascia dove il cuneo fiscale inizia a ridursi: verificare che la detrazione sia ancora applicata e nella misura corretta. La differenza tra le addizionali regionali assume un peso rilevante: trasferirsi dal Lazio al Friuli-Venezia Giulia puo\' significare un risparmio di 300-400 euro/anno. Considerare l\'apertura di un fondo pensione complementare: con l\'aliquota marginale al 33%, ogni 1.000 euro versati generano un risparmio fiscale di circa 330 euro.',
  },
  1700: {
    jobs: 'Un netto di 1.700 euro mensili (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' tipico di sviluppatori software con 3-5 anni di esperienza, commercialisti collaboratori di studio, ingegneri junior in aziende industriali, assistenti sociali nel pubblico impiego con anzianita\', e responsabili di punto vendita nella GDO. Nel settore bancario corrisponde al 2° livello con scatti di anzianita\'. E\' anche la retribuzione di farmacisti collaboratori, archivisti e bibliotecari con contratto pubblico a tempo pieno, e account manager in aziende di medie dimensioni.',
    finance: 'Con 1.700 euro netti al mese, il bilancio personale puo\' sostenere un affitto autonomo anche nelle citta\' del Nord (fino a 550-600 euro restando sotto il 35% del netto) e mantenere un margine di risparmio concreto. L\'allocazione ottimale prevede: 850 euro per spese necessarie, 340 euro per spese discrezionali, 340 euro per risparmio. A questo livello il versamento al fondo pensione complementare diventa particolarmente efficiente: la RAL superiore ai 28.000 euro implica un\'aliquota marginale del 33%, il che significa che ogni euro versato al fondo pensione "costa" effettivamente solo 67 centesimi. Il risparmio fiscale massimo (versando 5.164 euro/anno) e\' di circa 1.700 euro. Valutare anche le detrazioni per interessi passivi sul mutuo (fino a 760 euro/anno) se si acquista la prima casa.',
  },
  1800: {
    jobs: 'Con 1.800 euro netti al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) troviamo ingegneri con 3-5 anni di esperienza, sviluppatori full-stack mid-level, analisti finanziari junior in banca, quadri intermedi nel settore manifatturiero, coordinatori infermieristici, e insegnanti di scuola secondaria con oltre 20 anni di servizio. Nel CCNL Metalmeccanico corrisponde al livello D2, nel settore bancario al 1° livello. E\' anche lo stipendio di farmacisti con esperienza, geometri con ruolo di capo cantiere, e specialisti di digital marketing con 4-6 anni nel settore.',
    finance: 'A 1.800 euro netti mensili, il potere d\'acquisto consente una vita autonoma confortevole in tutte le citta\' italiane, con capacita\' di risparmio strutturata. Con una RAL di circa ' + fmtCurRound(ralDefault) + ' euro, si e\' nella piena operativita\' del secondo scaglione IRPEF (33%). L\'allocazione strategica del risparmio (360 euro/mese) dovrebbe prevedere: fondo emergenza (se non ancora completato a ' + fmtCurRound(1800 * 6) + ' euro), versamento al fondo pensione (almeno il contributo minimo per attivare il match del datore di lavoro), e PAC su un portafoglio diversificato (60% azionario, 40% obbligazionario). A questo livello di reddito, un mutuo sostenibile (rata massima 30% del netto, ovvero 540 euro) consente di finanziare un immobile di circa 150.000-170.000 euro con un anticipo del 20%.',
  },
  2000: {
    jobs: 'Uno stipendio netto di 2.000 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' la retribuzione di sviluppatori software senior, ingegneri meccanici ed elettronici con esperienza, commercialisti con proprio portafoglio clienti in studio, quadri aziendali in PMI, responsabili risorse umane in aziende di medie dimensioni, e analisti di gestione in banca. Nel settore IT e\' il livello dei DevOps engineer e dei product owner con 5-7 anni di esperienza. E\' anche lo stipendio di medici ospedalieri nei primi anni di specializzazione (post-formazione), controller di gestione senior, e project manager certificati nell\'edilizia e nell\'impiantistica.',
    finance: 'Con 2.000 euro netti al mese si entra nella fascia di reddito che consente una pianificazione finanziaria articolata. Il risparmio del 20% (400 euro/mese) puo\' essere suddiviso tra: fondo pensione complementare (massimizzare la deducibilita\' fino a 5.164 euro/anno con aliquota marginale al 33%), investimenti in ETF tramite PAC (200 euro/mese su un portafoglio globale), e accumulo per obiettivi specifici (anticipo immobiliare, formazione). La rata massima sostenibile per un mutuo e\' di circa 600 euro, compatibile con un finanziamento di 180.000-200.000 euro a 25 anni. A questo livello, la scelta della regione di residenza incide concretamente: la differenza tra le addizionali piu\' basse e piu\' alte vale circa 500-700 euro/anno.',
  },
  2200: {
    jobs: 'Un netto di 2.200 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' la retribuzione di team leader nel settore IT, ingegneri senior nell\'industria, responsabili commerciali con gestione di area, quadri nel CCNL Metalmeccanico (livello D3-E), avvocati con 5-8 anni di esperienza in studi strutturati, e funzionari pubblici di fascia alta con responsabilita\' di coordinamento. E\' anche lo stipendio di medici ospedalieri con qualche anno di servizio, farmacisti direttori di filiale, e consulenti aziendali con portafoglio clienti consolidato.',
    finance: 'Con 2.200 euro netti al mese il margine per costruire ricchezza nel tempo diventa significativo. Allocando 440 euro/mese al risparmio e all\'investimento, in 15 anni con un rendimento medio del 7% si puo\' accumulare un capitale di circa 110.000 euro. Le priorita\' finanziarie a questo livello sono: massimizzare il versamento al fondo pensione (con aliquota marginale al 33% il beneficio fiscale e\' elevato), diversificare gli investimenti tra azionario globale ed obbligazionario, e pianificare l\'acquisto della prima casa se non ancora effettuato. Un mutuo con rata di 660 euro (30% del netto) consente di acquistare un immobile fino a 200.000-230.000 euro nelle citta\' del Nord o un appartamento piu\' ampio nel Centro-Sud. Il TFR accantonato annualmente (circa ' + fmtCurRound(ralDefault / 13.5) + ' euro) puo\' essere destinato al fondo pensione con ulteriore vantaggio fiscale.',
  },
  2500: {
    jobs: 'Con 2.500 euro netti al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) troviamo profili come engineering manager, solution architect nel settore IT, responsabili di produzione industriale, dirigenti di PMI, medici specialisti a inizio carriera, notai praticanti in studi avviati, e commercialisti con studio autonomo consolidato. Nel settore bancario corrisponde a responsabili di filiale o vice-direttori. E\' anche la retribuzione di dirigenti scolastici nei primi anni, project manager senior nel settore delle costruzioni, e head of marketing in aziende di medie dimensioni.',
    finance: 'A 2.500 euro netti al mese la strategia finanziaria puo\' diventare sofisticata. La quota risparmiabile (500 euro/mese) consente di articolare il portafoglio su piu\' asset class. Una allocazione suggerita: 200 euro/mese nel fondo pensione (massimizzando il beneficio fiscale), 250 euro/mese in un PAC su ETF diversificato, e 50 euro/mese in liquidita\' ad alto rendimento per opportunita\' tattiche. Con una RAL di circa ' + fmtCurRound(ralDefault) + ' euro, l\'aliquota marginale IRPEF e\' al 33%, il che rende il fondo pensione molto vantaggioso: versando il massimo deducibile di 5.164 euro/anno si risparmiano circa 1.700 euro di tasse. La capacita\' di mutuo a questo reddito (rata sostenibile di 750 euro) consente l\'acquisto di immobili fino a 250.000-280.000 euro. Valutare anche polizze vita detraibili (fino a 530 euro/anno di detrazione) e investimenti in PIR per l\'esenzione fiscale sui capital gain.',
  },
  2800: {
    jobs: 'Un netto di 2.800 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) corrisponde a ruoli di senior management: direttori di funzione in aziende medio-grandi, principal consultant in societa\' di consulenza, lead developer e CTO di startup in crescita, medici ospedalieri con specializzazione e anzianita\', e dirigenti nel settore assicurativo. Nel settore pubblico, e\' lo stipendio di dirigenti di seconda fascia con incarichi di responsabilita\'. E\' anche la retribuzione di avvocati senior in studi legali internazionali, responsabili di area in societa\' di revisione (Big Four), e country manager di aziende estere in Italia.',
    finance: 'Con 2.800 euro netti al mese le necessita\' di base sono ampiamente coperte e la pianificazione finanziaria puo\' focalizzarsi sulla crescita patrimoniale. Il risparmio del 25-30% (700-840 euro/mese) permette di costruire un portafoglio diversificato: fondo pensione al massimo deducibile (5.164 euro/anno), PAC su ETF globali (300-400 euro/mese), ed eventualmente investimenti immobiliari tramite crowdfunding o REITs. Con una RAL di circa ' + fmtCurRound(ralDefault) + ' euro, parte del reddito ricade nello scaglione IRPEF al 43%: la deduzione per il fondo pensione genera un risparmio fiscale fino a 2.200 euro/anno. La capacita\' di mutuo (rata sostenibile di 840 euro) consente di finanziare immobili di valore elevato. A questo livello patrimoniale, e\' consigliabile un confronto con un consulente finanziario indipendente per ottimizzare l\'asset allocation e la pianificazione successoria.',
  },
  3000: {
    jobs: 'Uno stipendio netto di 3.000 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) e\' tipico di posizioni dirigenziali in aziende strutturate: direttori commerciali, VP Engineering nel tech, partner junior in studi professionali, medici primari ospedalieri, e dirigenti industriali con responsabilita\' di P&L. Nel settore finanziario corrisponde a portfolio manager, responsabili di desk di trading, e direttori di rete bancaria. E\' anche la retribuzione di docenti universitari di seconda fascia, magistrati con anzianita\', e general manager di filiali italiane di multinazionali di medie dimensioni.',
    finance: 'Con 3.000 euro netti al mese la gestione finanziaria richiede una strategia strutturata. La RAL di circa ' + fmtCurRound(ralDefault) + ' euro comporta un\'aliquota marginale del 43%, il che rende essenziale l\'ottimizzazione fiscale. Priorita\': massimizzare il fondo pensione (risparmio fiscale di oltre 2.200 euro/anno), valutare il welfare aziendale come componente della retribuzione (fringe benefit, auto aziendale, assicurazione sanitaria integrativa). Con un risparmio di 900 euro/mese (30% del netto), in 15 anni si puo\' accumulare un capitale di oltre 250.000 euro. Il patrimonio va diversificato: 40-50% azionario globale, 20-30% obbligazionario, 10-20% immobiliare. Valutare un consulente finanziario indipendente (fee-only) per la pianificazione previdenziale: l\'aliquota marginale alta rende il fondo pensione e i fondi sanitari integrativi particolarmente vantaggiosi.',
  },
  3500: {
    jobs: 'Con 3.500 euro netti al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) siamo nell\'ambito dell\'alta dirigenza: C-level (CFO, COO, CTO) di aziende medio-grandi, partner di studi legali e di consulenza, medici primari con incarichi direttivi, dirigenti di prima fascia nel settore pubblico, e country director di multinazionali. Nel settore tech, corrisponde a VP o SVP in scale-up e grandi aziende. E\' anche la retribuzione di docenti universitari ordinari con anzianita\', dirigenti bancari di alto livello, e managing director di societa\' di revisione.',
    finance: 'A 3.500 euro netti al mese la strategia finanziaria deve essere gestita con competenze specialistiche. Con una RAL di circa ' + fmtCurRound(ralDefault) + ' euro, la tassazione marginale al 43% impone un\'attenzione particolare all\'efficienza fiscale di ogni componente retributiva. Strategie chiave: negoziare pacchetti retributivi con forte componente di welfare aziendale (auto, previdenza integrativa, assicurazione sanitaria estesa al nucleo familiare); massimizzare il fondo pensione (risparmio fiscale di oltre 2.200 euro/anno); valutare investimenti in PIR per l\'esenzione sui capital gain fino a 150.000 euro. Il risparmio mensile (1.000-1.200 euro) consente di costruire un portafoglio robusto in tempi relativamente brevi: con un PAC di 1.000 euro/mese e rendimento medio del 7%, il capitale accumulato in 10 anni supera i 170.000 euro. Considerare la pianificazione successoria e la protezione patrimoniale con polizze vita rivalutabili.',
  },
  4000: {
    jobs: 'Un netto di 4.000 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) corrisponde alla fascia alta della dirigenza italiana: CEO e amministratori delegati di aziende di medie dimensioni, partner senior di studi professionali di primo piano, direttori generali di enti pubblici, e managing director nel settore bancario e finanziario. Nel settore tecnologico, e\' il livello di VP in big tech o founder di startup ben finanziate con stipendio strutturato. E\' anche la retribuzione di primari ospedalieri con incarichi apicali, presidenti di sezione in magistratura, e responsabili di practice in grandi societa\' di consulenza.',
    finance: 'Con 4.000 euro netti al mese, la pianificazione patrimoniale deve essere globale. La RAL di circa ' + fmtCurRound(ralDefault) + ' euro implica una tassazione media superiore al 40%: ogni strategia di ottimizzazione ha un impatto significativo. Il risparmio mensile (1.200-1.500 euro) va allocato in modo diversificato: fondo pensione al massimo deducibile, PAC su ETF globali con componente di mercati emergenti, immobiliare (diretto o tramite REITs), e una quota in strumenti alternativi (private equity tramite ELTIF con benefici fiscali). A questo livello, il massimale contributivo INPS non e\' ancora rilevante ma e\' importante pianificare la pensione integrativa, dato che il tasso di sostituzione INPS per redditi medio-alti e\' significativamente inferiore alla media. Valutare la costituzione di una societa\' per attivita\' di consulenza accessorie: il regime societario puo\' essere fiscalmente piu\' efficiente per redditi extra rispetto alla tassazione IRPEF al 43%.',
  },
  5000: {
    jobs: 'Uno stipendio netto di 5.000 euro al mese (RAL circa ' + fmtCurRound(ralDefault) + ' euro) rappresenta il vertice della retribuzione da lavoro dipendente in Italia, riservato a meno del 2% dei lavoratori. I profili tipici includono: CEO di aziende con fatturato superiore ai 50 milioni, partner equity in studi legali e di consulenza di primo livello, direttori generali di grandi enti pubblici, chirurghi e primari ospedalieri di fama nazionale, e country manager di grandi multinazionali. Nel settore finanziario corrisponde a managing director in investment banking e head of desk in asset management. E\' anche la retribuzione di rettori universitari, presidenti di autorita\' garanti, e general counsel di gruppi industriali quotati.',
    finance: 'Con 5.000 euro netti al mese la gestione finanziaria richiede un approccio di private banking. La RAL di circa ' + fmtCurRound(ralDefault) + ' euro comporta un\'aliquota media prossima al 45%, rendendo la pianificazione fiscale una componente essenziale della strategia retributiva. Le leve di ottimizzazione includono: massimizzazione del fondo pensione (risparmio fiscale di oltre 2.200 euro/anno), utilizzo strategico del welfare aziendale (che a questo livello puo\' valere 5.000-10.000 euro/anno in servizi detassati), e negoziazione di componenti variabili ottimizzate fiscalmente (stock option, phantom shares). Il risparmio mensile (1.500-2.000 euro) deve essere gestito con un\'asset allocation sofisticata: portafoglio globale diversificato tra azioni, obbligazioni, immobiliare e alternativi. A questo livello patrimoniale e\' essenziale un consulente finanziario indipendente (fee-only), la pianificazione successoria, e la verifica dell\'esposizione al rischio di concentrazione (troppo patrimonio nell\'azienda per cui si lavora). Il TFR annuo accantonato (circa ' + fmtCurRound(ralDefault / 13.5) + ' euro) rappresenta una somma significativa: valutare se destinarlo al fondo pensione o lasciarlo in azienda in base alla propria situazione previdenziale.',
  },
};

const nettoProfile = nettoProfiles[nettoTarget];

// FAQs
const faqs = [
  {
    question: `Quanto lordo serve per guadagnare ${fmtCurRound(nettoTarget)} euro netti al mese?`,
    answer: `Per ottenere circa ${fmtCurRound(nettoTarget)} euro netti al mese servono circa ${fmtCurRound(ralDefault)} euro di RAL (Retribuzione Annua Lorda), considerando 13 mensilita', contratto a tempo indeterminato in Lombardia, senza carichi familiari.`,
  },
  {
    question: `${fmtCurRound(nettoTarget)} euro netti al mese sono un buon stipendio in Italia?`,
    answer: `Uno stipendio di ${fmtCurRound(nettoTarget)} euro netti al mese si colloca a un livello ${market.livello} rispetto alla media nazionale. Lo stipendio mediano in Italia e' di circa 1.400 euro netti mensili (dati ISTAT). Il potere d'acquisto dipende anche dalla citta' di residenza.`,
  },
  {
    question: `La RAL necessaria cambia in base alla regione?`,
    answer: `Si', le addizionali regionali IRPEF variano significativamente tra regioni. Per ottenere ${fmtCurRound(nettoTarget)} euro netti, la RAL necessaria puo' variare di diverse centinaia di euro tra la regione piu' conveniente e quella piu' costosa. Le regioni con addizionali piu' basse sono generalmente Friuli-Venezia Giulia, Sardegna e Veneto.`,
  },
  {
    question: `Come viene calcolato lo stipendio netto dal lordo?`,
    answer: `Dallo stipendio lordo si sottraggono: contributi INPS (9,19%), IRPEF calcolata sugli scaglioni vigenti (23%, 33%, 43%), addizionali regionali e comunali. Si aggiungono poi le detrazioni per lavoro dipendente, il cuneo fiscale e l'eventuale trattamento integrativo (ex Bonus Renzi).`,
  },
  {
    question: `Con 14 mensilita' il netto mensile cambia?`,
    answer: `Con 14 mensilita' la RAL rimane la stessa, ma il netto annuo viene diviso per 14 anziche' 13, quindi il netto mensile sara' inferiore (circa il 7% in meno per singola mensilita'), compensato dalle due mensilita' aggiuntive. Il netto annuo totale resta sostanzialmente invariato.`,
  },
];

// SEO
const title = `${fmtCurRound(nettoTarget)} Euro Netti al Mese: Quanta RAL Serve? Calcolo 2026`;
const description = `Per guadagnare ${fmtCurRound(nettoTarget)} euro netti al mese servono circa ${fmtCurRound(ralDefault)} euro lordi (RAL). Calcolo 2026 con IRPEF, INPS 9,19%, detrazioni e confronto netto tra le regioni.`;

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Stipendio Mensile', url: `${SITE.url}/stipendio-mensile/` },
  { name: `${fmtCurRound(nettoTarget)} €`, url: `${SITE.url}/stipendio-mensile/${slug}/` },
];

const schemaString = JSON.stringify([
  breadcrumbSchema(breadcrumbs),
  faqSchema(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: `${SITE.url}/stipendio-mensile/${slug}/`,
    inLanguage: SITE.locale,
    isPartOf: { '@type': 'WebSite', name: SITE.name, url: `${SITE.url}/` },
    dateModified: '2026-01-15',
  },
]);
---

<Layout
  title={title}
  description={description}
  schema={schemaString}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="py-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center gap-1.5">
            {index > 0 && (
              <svg class="h-3.5 w-3.5 flex-shrink-0 text-gray-400 dark:text-gray-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            )}
            {index < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-brand transition-colors">
                {crumb.name}
              </a>
            ) : (
              <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">
                {crumb.name}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- H1 Hero -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 dark:from-gray-800 dark:to-gray-900 px-6 py-10 sm:px-10 sm:py-14 mb-10">
      <div class="relative z-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
          Stipendio Mensile di {fmtCurRound(nettoTarget)} &euro; Netti: Quale RAL Serve nel {SITE.annoFiscale}?
        </h1>
        <p class="mt-4 text-lg text-gray-300 max-w-2xl">
          Per guadagnare <strong class="text-white">{fmtCurRound(nettoTarget)} &euro; netti al mese</strong> servono circa <strong class="text-white">{fmtCurRound(ralDefault)} &euro; di RAL</strong> (su 13 mensilita').
        </p>
        <div class="mt-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-green-500/10 px-3 py-1 text-xs font-medium text-green-400 ring-1 ring-green-500/30">
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
            </svg>
            Aggiornato {SITE.annoFiscale}
          </span>
        </div>
        <div class="mt-8">
          <a
            href={`/calcolo-stipendio-lordo?netto=${nettoTarget}`}
            class="inline-flex items-center gap-2 rounded-lg bg-brand px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-dark transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            Calcola il tuo caso
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
      <div class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-brand"></div>
        <div class="absolute -left-10 -bottom-10 h-60 w-60 rounded-full bg-brand"></div>
      </div>
    </section>

    <!-- H2: RAL Necessaria per Regione -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        RAL Necessaria per Regione
      </h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Le addizionali regionali IRPEF influenzano significativamente il netto. Ecco la RAL necessaria per ottenere circa {fmtCurRound(nettoTarget)} &euro; netti al mese in ogni regione d'Italia.
      </p>
      <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <th class="px-4 py-3 text-left font-semibold text-gray-900 dark:text-white">Regione</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">RAL Necessaria</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Netto Mensile</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Add. Regionale</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-900 dark:text-white">Aliquota Media</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
            {regionResults.map((r) => (
              <tr class:list={[
                'transition-colors',
                r.codice === defaultRegione
                  ? 'bg-brand/5 dark:bg-brand/10'
                  : 'hover:bg-gray-50 dark:hover:bg-gray-800/30',
              ]}>
                <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">
                  {r.nome}
                  {r.codice === defaultRegione && (
                    <span class="ml-1.5 text-xs text-brand font-normal">(rif.)</span>
                  )}
                </td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCurRound(r.ral)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCur(r.nettoMensile)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtCur(r.addizionaleRegionale)} &euro;</td>
                <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300">{fmtPct(r.aliquotaMedia)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
        * Calcoli su 13 mensilita', contratto indeterminato, senza carichi familiari. Addizionale comunale media nazionale.
      </p>
    </section>

    <!-- H2: Dettaglio Imposte -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Dettaglio Imposte con RAL di {fmtCurRound(ralDefault)} &euro;
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Colonna sinistra: breakdown -->
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
          <div class="bg-gray-50 dark:bg-gray-800/50 px-5 py-3 border-b border-gray-200 dark:border-gray-800">
            <h3 class="font-semibold text-gray-900 dark:text-white">Dal Lordo al Netto</h3>
          </div>
          <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">RAL (Lordo Annuo)</span>
              <span class="font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.ral)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Contributi INPS (9,19%)</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.contributiINPS)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3 bg-gray-50/50 dark:bg-gray-800/25">
              <span class="text-gray-600 dark:text-gray-400">Imponibile Fiscale</span>
              <span class="font-medium text-gray-900 dark:text-white">{fmtCur(dettaglio.imponibileFiscale)} &euro;</span>
            </div>
            {dettaglio.cuneoFiscaleSommaEsente > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Cuneo Fiscale (somma esente)</span>
                <span class="text-green-600 dark:text-green-400">-{fmtCur(dettaglio.cuneoFiscaleSommaEsente)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">IRPEF Lorda</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.irpefLorda)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Detrazioni Lavoro Dip.</span>
              <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.detrazioneLavoroDipendente)} &euro;</span>
            </div>
            {dettaglio.cuneoFiscaleDetrazione > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Cuneo Fiscale (detrazione)</span>
                <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.cuneoFiscaleDetrazione)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">IRPEF Netta</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.irpefNetta)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Addizionale Regionale</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.addizionaleRegionale)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-gray-600 dark:text-gray-400">Addizionale Comunale</span>
              <span class="text-red-600 dark:text-red-400">-{fmtCur(dettaglio.addizionaleComunale)} &euro;</span>
            </div>
            {dettaglio.trattamentoIntegrativo > 0 && (
              <div class="flex justify-between px-5 py-3">
                <span class="text-gray-600 dark:text-gray-400">Trattamento Integrativo</span>
                <span class="text-green-600 dark:text-green-400">+{fmtCur(dettaglio.trattamentoIntegrativo)} &euro;</span>
              </div>
            )}
            <div class="flex justify-between px-5 py-4 bg-gray-900 dark:bg-gray-800">
              <span class="font-semibold text-white">Netto Annuo</span>
              <span class="font-bold text-white text-lg">{fmtCur(dettaglio.nettoAnnuo)} &euro;</span>
            </div>
            <div class="flex justify-between px-5 py-4 bg-brand/10 dark:bg-brand/20">
              <span class="font-semibold text-brand">Netto Mensile (x{dettaglio.mensilita})</span>
              <span class="font-bold text-brand text-lg">{fmtCur(dettaglio.nettoMensile)} &euro;</span>
            </div>
          </div>
        </div>

        <!-- Colonna destra: scaglioni IRPEF e riepilogo -->
        <div class="space-y-6">
          <!-- Scaglioni IRPEF -->
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
            <div class="bg-gray-50 dark:bg-gray-800/50 px-5 py-3 border-b border-gray-200 dark:border-gray-800">
              <h3 class="font-semibold text-gray-900 dark:text-white">Scaglioni IRPEF Applicati</h3>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-gray-800">
              {irpefDetail.dettaglioScaglioni.map((s) => (
                <div class="flex justify-between px-5 py-3">
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">{s.scaglione}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Aliquota {fmtPct(s.aliquota)}</p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">{fmtCur(s.impostaScaglione)} &euro;</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">su {fmtCur(s.imponibileInScaglione)} &euro;</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Riepilogo aliquote -->
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Riepilogo Aliquote</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Aliquota media effettiva</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.aliquotaMedia)}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Aliquota marginale</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.aliquotaMarginale)}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Cuneo fiscale totale</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtPct(dettaglio.cuneoFiscaleTotale)}</span>
              </div>
              <hr class="border-gray-200 dark:border-gray-700" />
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">Costo azienda</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.costoAzienda)} &euro;</span>
              </div>
              <div class="flex justify-between">
                <span class="text-sm text-gray-600 dark:text-gray-400">TFR annuo accantonato</span>
                <span class="text-sm font-semibold text-gray-900 dark:text-white">{fmtCur(dettaglio.tfrAnnuo)} &euro;</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- H2: Confronto con il Mercato -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Confronto con il Mercato del Lavoro
      </h2>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand/10 dark:bg-brand/20 flex items-center justify-center">
            <svg class="h-5 w-5 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M1 2.75A.75.75 0 0 1 1.75 2h16.5a.75.75 0 0 1 0 1.5H18v8.75A2.75 2.75 0 0 1 15.25 15h-1.072l.798 3.06a.75.75 0 0 1-1.452.38L13.41 18H6.59l-.114.44a.75.75 0 0 1-1.452-.38L5.822 15H4.75A2.75 2.75 0 0 1 2 12.25V3.5h-.25A.75.75 0 0 1 1 2.75Z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">
              Livello retributivo: <span class="text-brand">{market.livello}</span>
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
              {market.contesto}
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              <strong class="text-gray-900 dark:text-white">Settori tipici:</strong> {market.settori}.
            </p>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">RAL necessaria</p>
            <p class="text-xl font-bold text-gray-900 dark:text-white">{fmtCurRound(ralDefault)} &euro;</p>
          </div>
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Lordo mensile</p>
            <p class="text-xl font-bold text-gray-900 dark:text-white">{fmtCur(dettaglio.ralMensile)} &euro;</p>
          </div>
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 p-4 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Netto mensile</p>
            <p class="text-xl font-bold text-brand">{fmtCur(dettaglio.nettoMensile)} &euro;</p>
          </div>
        </div>

        <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
          Fonti: elaborazioni su dati <a href="https://www.istat.it" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">ISTAT</a> e <a href="https://www.inps.it" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">INPS</a>.
          I riferimenti al mercato del lavoro sono indicativi e possono variare in base a esperienza, settore, dimensione aziendale e area geografica.
        </p>
      </div>
    </section>

    <!-- Job profiles (unique per amount) -->
    {nettoProfile && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          Chi Guadagna {fmtCurRound(nettoTarget)} &euro; Netti al Mese?
        </h2>
        <div class="prose prose-gray dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 leading-relaxed">
          <p>{nettoProfile.jobs}</p>
        </div>
      </section>
    )}

    <!-- Financial context (unique per amount) -->
    {nettoProfile && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
          Gestione Finanziaria con {fmtCurRound(nettoTarget)} &euro; Netti al Mese
        </h2>
        <div class="prose prose-gray dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 leading-relaxed">
          <p>{nettoProfile.finance}</p>
        </div>
      </section>
    )}

    <!-- H2: FAQ -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Domande Frequenti
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
            <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-semibold text-gray-900 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              {faq.question}
              <svg class="h-5 w-5 flex-shrink-0 text-gray-400 group-open:rotate-180 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Adjacent links -->
    <nav aria-label="Importi mensili correlati" class="mb-16 flex flex-col sm:flex-row gap-4">
      {prevAmount && (
        <a
          href={`/stipendio-mensile/${prevAmount}-euro/`}
          class="flex-1 group flex items-center gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-brand dark:hover:border-brand transition-colors"
        >
          <svg class="h-5 w-5 text-gray-400 group-hover:text-brand transition-colors" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
          </svg>
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Importo precedente</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-brand transition-colors">
              {fmtCurRound(prevAmount)} &euro; netti/mese
            </p>
          </div>
        </a>
      )}
      {nextAmount && (
        <a
          href={`/stipendio-mensile/${nextAmount}-euro/`}
          class="flex-1 group flex items-center justify-end gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-brand dark:hover:border-brand transition-colors text-right"
        >
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Importo successivo</p>
            <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-brand transition-colors">
              {fmtCurRound(nextAmount)} &euro; netti/mese
            </p>
          </div>
          <svg class="h-5 w-5 text-gray-400 group-hover:text-brand transition-colors" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </a>
      )}
    </nav>
  </div>
</Layout>
