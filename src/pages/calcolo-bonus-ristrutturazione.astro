              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">10</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">Art. 16-bis TUIR</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 font-medium">Ristrutturazione (altri immobili)</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">36%</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">96.000 &euro;</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">10</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">Art. 16-bis TUIR</td>
            </tr>
