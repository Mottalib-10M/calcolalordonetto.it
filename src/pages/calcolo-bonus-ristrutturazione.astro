              <th class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center font-semibold">Quote annuali</th>
              <th class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center font-semibold">Norma</th>
            </tr>
