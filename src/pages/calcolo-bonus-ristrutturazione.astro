              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">96.000 &euro;</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">5</td>
              <td class="border border-gray-200 dark:border-gray-700 px-4 py-3 text-center">D.L. 63/2013</td>
            </tr>
            <tr class="bg-gray-50 dark:bg-gray-800/50">
