---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
import { breadcrumbSchema } from '../lib/seo';

const title = 'Aggiornamenti Fiscali Italia 2026: Novita\' IRPEF, INPS e Tasse';
const description = "Le ultime novita' fiscali italiane: aggiornamenti IRPEF, contributi INPS, cuneo fiscale, scadenze e modifiche normative che impattano il tuo stipendio netto.";

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Aggiornamenti', url: `${SITE.url}/aggiornamenti/` },
];

const schema = JSON.stringify([
  breadcrumbSchema(breadcrumbs),
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `${SITE.url}/aggiornamenti/`,
    inLanguage: SITE.locale,
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: `${SITE.url}/`,
    },
  },
]);

interface NewsItem {
  title: string;
  date: string;
  summary: string;
  category: 'irpef' | 'inps' | 'cuneo' | 'detrazioni' | 'scadenze' | 'altro';
  body: string;
  relatedCalc?: { name: string; href: string };
}

const categoryLabels: Record<string, { label: string; color: string }> = {
  irpef: { label: 'IRPEF', color: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400' },
  inps: { label: 'INPS', color: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' },
  cuneo: { label: 'Cuneo Fiscale', color: 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' },
  detrazioni: { label: 'Detrazioni', color: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400' },
  scadenze: { label: 'Scadenze', color: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400' },
  altro: { label: 'Generale', color: 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-400' },
};

const news: NewsItem[] = [
  {
    title: 'Confermati i tre scaglioni IRPEF per il 2026: 23%, 33% e 43%',
    date: '2026-01-15',
    category: 'irpef',
    summary: "La Legge di Bilancio 2026 conferma la struttura a tre scaglioni introdotta nel 2025, con il secondo scaglione ridotto dal 35% al 33%.",
    body: "La Legge di Bilancio 2026 ha reso strutturale la riforma dell'IRPEF a tre scaglioni. Le aliquote confermate sono: 23% per redditi fino a 28.000 euro, 33% da 28.001 a 50.000 euro e 43% oltre i 50.000 euro. Rispetto al 2024, il secondo scaglione e' stato ridotto dal 35% al 33%, con un risparmio massimo di 240 euro annui per i contribuenti con reddito superiore a 50.000 euro. Il limite del primo scaglione resta a 28.000 euro (innalzato dai precedenti 15.000 euro nel 2024). Il governo ha annunciato l'intenzione di proseguire il percorso di semplificazione verso un sistema a due aliquote nelle prossime legislature.",
    relatedCalc: { name: 'Calcolo IRPEF', href: '/calcolo-irpef/' },
  },
  {
    title: 'Cuneo fiscale 2026: detrazione strutturale fino a 32.000 euro',
    date: '2026-01-15',
    category: 'cuneo',
    summary: "Il taglio del cuneo fiscale diventa permanente con la Legge di Bilancio 2026, confermando il doppio meccanismo somma esente + detrazione.",
    body: "Dal 2026 il taglio del cuneo fiscale e' strutturale. Per redditi fino a 20.000 euro, una quota del reddito e' esente da tassazione (dal 4,8% al 7,1% a seconda della fascia). Per redditi tra 20.001 e 32.000 euro, spetta una detrazione IRPEF di 1.000 euro/anno. Tra 32.001 e 40.000 euro la detrazione si riduce progressivamente. Il meccanismo sostituisce definitivamente il taglio contributivo temporaneo del 2023-2024 (6-7 punti di contributi INPS), con il vantaggio di non penalizzare l'accantonamento pensionistico. Per un lavoratore con RAL 25.000 euro, il beneficio netto annuo e' di circa 1.000-1.100 euro.",
    relatedCalc: { name: 'Calcola Stipendio Netto', href: '/' },
  },
  {
    title: 'Massimale contributivo INPS 2026: aggiornato a 119.650 euro',
    date: '2026-01-10',
    category: 'inps',
    summary: "L'INPS ha comunicato il nuovo massimale contributivo per il 2026, rivalutato in base all'indice ISTAT dei prezzi al consumo.",
    body: "Con circolare di gennaio 2026, l'INPS ha fissato il massimale contributivo annuo a 119.650 euro (in lieve aumento rispetto ai 119.650 del 2025, grazie alla rivalutazione ISTAT). Per i lavoratori con primo accredito contributivo successivo al 1° gennaio 1996 (sistema contributivo puro), la retribuzione eccedente questo importo non e' soggetta a contribuzione previdenziale. Questo significa che chi guadagna oltre 119.650 euro lordi non versa contributi INPS sulla parte eccedente, con un effetto positivo sul netto mensile ma negativo sulla futura pensione. Per compensare, e' fortemente consigliato il versamento al fondo pensione complementare.",
    relatedCalc: { name: 'Calcolo Pensione', href: '/calcolo-pensione/' },
  },
  {
    title: 'Fringe benefit 2026: confermata la soglia a 2.000 euro per chi ha figli',
    date: '2026-01-08',
    category: 'detrazioni',
    summary: "La soglia di esenzione dei fringe benefit resta a 2.000 euro per i lavoratori con figli a carico e 1.000 euro per i neoassunti.",
    body: "Per il 2026, la soglia di esenzione fiscale dei fringe benefit e' confermata a 258,23 euro annui per la generalita' dei lavoratori. Tuttavia, sono previste soglie maggiorate: 1.000 euro per i lavoratori neoassunti che trasferiscono la residenza di oltre 100 km e 2.000 euro per i dipendenti con figli a carico. Oltre la soglia applicabile, l'intero valore del fringe benefit concorre al reddito imponibile. I fringe benefit includono: auto aziendale ad uso promiscuo, buoni acquisto, rimborso utenze domestiche (per chi ha figli), e alloggio. Nota bene: i buoni pasto sono disciplinati separatamente e hanno un limite di esenzione di 8 euro/giorno (elettronici) o 4 euro/giorno (cartacei).",
    relatedCalc: { name: 'Calcolo Busta Paga', href: '/calcolo-busta-paga/' },
  },
  {
    title: 'Scadenze fiscali giugno 2026: saldo IRPEF e acconto IMU',
    date: '2026-06-01',
    category: 'scadenze',
    summary: "Le principali scadenze fiscali di giugno 2026: il 16 giugno scade l'acconto IMU, il 30 giugno il saldo IRPEF e il primo acconto.",
    body: "Giugno e' tradizionalmente il mese piu' impegnativo dal punto di vista fiscale. Le scadenze principali del 2026 sono: il 16 giugno, termine per il versamento dell'acconto IMU (prima rata pari al 50% dell'imposta dovuta nell'anno precedente); il 30 giugno, termine per il versamento del saldo IRPEF 2025 e del primo acconto IRPEF 2026 (pari al 40% dell'imposta dovuta, per chi sceglie la rateizzazione in due acconti). I lavoratori dipendenti che hanno solo redditi da lavoro dipendente e presentano il modello 730 ricevono eventuali rimborsi direttamente in busta paga a partire da luglio. Per i lavoratori autonomi con modello Redditi PF, il termine e' il 30 giugno con possibilita' di differimento al 30 luglio con maggiorazione dello 0,40%.",
  },
  {
    title: 'Assegno Unico 2026: importi rivalutati e nuove soglie ISEE',
    date: '2026-03-01',
    category: 'detrazioni',
    summary: "Gli importi dell'Assegno Unico Universale per i figli sono stati rivalutati all'inflazione. Nuove soglie ISEE per le maggiorazioni.",
    body: "Dal 1° marzo 2026, gli importi dell'Assegno Unico Universale (AUU) sono stati rivalutati in base all'indice ISTAT. L'importo base per figlio minorenne va da un minimo di 57 euro/mese (ISEE superiore a 45.574 euro o assenza di ISEE) a un massimo di 199,40 euro/mese (ISEE fino a 17.090 euro). Le maggiorazioni sono confermate: +30% per famiglie numerose (3+ figli), +50% per figli sotto un anno, importo pieno per figli con disabilita' senza limiti di eta'. L'AUU non transita in busta paga e non e' incluso nei calcoli dello stipendio netto, ma va considerato nel bilancio familiare complessivo. La domanda si rinnova automaticamente; e' necessario aggiornare l'ISEE entro il 28 febbraio per ricevere gli importi corretti da marzo.",
    relatedCalc: { name: 'Calcolo ISEE', href: '/calcolo-isee/' },
  },
];

const dateFormatter = new Intl.DateTimeFormat('it-IT', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={title}
  description={description}
  canonical={`${SITE.url}/aggiornamenti/`}
  schema={schema}
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        <li class="flex items-center gap-1.5">
          <a href="/" class="hover:text-brand transition-colors">Home</a>
        </li>
        <li class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 flex-shrink-0 text-gray-400 dark:text-gray-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
          <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">Aggiornamenti</span>
        </li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white tracking-tight mb-4">
      Aggiornamenti Fiscali {SITE.annoFiscale}
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-10">
      Le ultime novita' su IRPEF, contributi INPS, cuneo fiscale, detrazioni e scadenze che impattano il tuo stipendio netto. Aggiornamenti verificati e riferiti alle fonti ufficiali.
    </p>

    <!-- News timeline -->
    <div class="space-y-8">
      {news.map((item) => {
        const cat = categoryLabels[item.category];
        return (
          <article class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
            <div class="p-6">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${cat.color}`}>
                  {cat.label}
                </span>
                <time datetime={item.date} class="text-xs text-gray-500 dark:text-gray-400">
                  {dateFormatter.format(new Date(item.date))}
                </time>
              </div>
              <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
                {item.title}
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-400 font-medium mb-4">
                {item.summary}
              </p>
              <details class="group">
                <summary class="flex cursor-pointer items-center gap-2 text-sm font-medium text-brand hover:text-brand-dark transition-colors list-none">
                  <span>Leggi tutto</span>
                  <svg class="h-4 w-4 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="mt-4 text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                  <p>{item.body}</p>
                  {item.relatedCalc && (
                    <p class="mt-4">
                      <a
                        href={item.relatedCalc.href}
                        class="inline-flex items-center gap-1.5 text-sm font-medium text-brand hover:text-brand-dark transition-colors"
                      >
                        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
                        </svg>
                        Calcola l'impatto con {item.relatedCalc.name}
                      </a>
                    </p>
                  )}
                </div>
              </details>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Sources -->
    <aside class="mt-12 rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
        Fonti
      </h2>
      <ul class="mt-3 space-y-1.5 text-sm text-gray-600 dark:text-gray-400">
        <li>
          <a href="https://www.agenziaentrate.gov.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">Agenzia delle Entrate</a>: circolari e risoluzioni ufficiali
        </li>
        <li>
          <a href="https://www.inps.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">INPS</a>: circolari contributive e previdenziali
        </li>
        <li>
          <a href="https://www.gazzettaufficiale.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">Gazzetta Ufficiale</a>: testi normativi
        </li>
      </ul>
    </aside>

    <!-- CTA -->
    <section class="mt-12 mb-16 rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 dark:from-gray-800 dark:to-gray-900 px-6 py-10 sm:px-10 sm:py-12 text-center">
      <h2 class="text-2xl font-bold text-white">Verifica l'impatto sul tuo stipendio</h2>
      <p class="mt-3 text-gray-300 max-w-xl mx-auto">
        Calcola il tuo stipendio netto con le aliquote e i parametri aggiornati al {SITE.annoFiscale}.
      </p>
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-dark transition-colors"
      >
        Calcola Stipendio Netto
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
        </svg>
      </a>
    </section>
  </div>
</Layout>
