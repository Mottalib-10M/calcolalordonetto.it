        <tr>
          <td class="py-3 pr-4 text-gray-900 dark:text-gray-100">Ricavi</td>
          <td class="py-3 px-4 text-right tabular-nums text-gray-900 dark:text-gray-100">50.000 &euro;</td>
          <td class="py-3 pl-4 text-right tabular-nums text-gray-900 dark:text-gray-100">50.000 &euro;</td>
        </tr>
        <tr>
          <td class="py-3 pr-4 text-gray-900 dark:text-gray-100">Costi dedotti</td>
          <td class="py-3 px-4 text-right tabular-nums text-gray-900 dark:text-gray-100">11.000 &euro; (forf. 22%)</td>
