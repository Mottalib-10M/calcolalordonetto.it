          <td class="py-3 px-4 text-right tabular-nums text-gray-900 dark:text-gray-100">39.000 &euro;</td>
          <td class="py-3 pl-4 text-right tabular-nums text-gray-900 dark:text-gray-100">42.500 &euro;</td>
        </tr>
        <tr>
          <td class="py-3 pr-4 text-gray-900 dark:text-gray-100">Imposte sul reddito</td>
          <td class="py-3 px-4 text-right tabular-nums text-gray-900 dark:text-gray-100">5.850 &euro; (15%)</td>
          <td class="py-3 pl-4 text-right tabular-nums text-gray-900 dark:text-gray-100">~11.225 &euro; (IRPEF + add.)</td>
        </tr>
        <tr>
          <td class="py-3 pr-4 text-gray-900 dark:text-gray-100">Contributi INPS</td>
          <td class="py-3 px-4 text-right tabular-nums text-gray-900 dark:text-gray-100">10.167 &euro;</td>
          <td class="py-3 pl-4 text-right tabular-nums text-gray-900 dark:text-gray-100">11.080 &euro;</td>
        </tr>
        <tr class="border-t-2 border-gray-300 dark:border-gray-600">
          <td class="py-3 pr-4 text-gray-900 dark:text-white font-bold">Carico totale</td>
          <td class="py-3 px-4 text-right tabular-nums text-green-600 dark:text-green-400 font-bold">16.017 &euro;</td>
          <td class="py-3 pl-4 text-right tabular-nums text-red-600 dark:text-red-400 font-bold">~22.305 &euro;</td>
