          <th class="py-3 px-4 text-right font-semibold text-gray-700 dark:text-gray-300">Forfettario</th>
          <th class="py-3 pl-4 text-right font-semibold text-gray-700 dark:text-gray-300">Ordinario</th>
        </tr>
      </thead>
