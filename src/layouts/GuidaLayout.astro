---
import Layout from './Layout.astro';
import { SITE } from '../config';
import type { Lang } from '../i18n/types';
import { t } from '../i18n/index';
import { breadcrumbSchema, faqSchema } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  datePublished: string;
  dateModified?: string;
  breadcrumbs: { name: string; url: string }[];
  faqs?: { question: string; answer: string }[];
  lang?: Lang;
}

const {
  title,
  description,
  canonical,
  ogImage,
  datePublished,
  dateModified,
  breadcrumbs,
  faqs,
  lang = 'it',
} = Astro.props;

const canonicalURL = canonical || Astro.url.href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalURL,
  datePublished,
  dateModified: dateModified || datePublished,
  inLanguage: lang === 'en' ? SITE.localeEn : SITE.locale,
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: `${SITE.url}/`,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: `${SITE.url}/`,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE.url}/logo-light.svg`,
    },
  },
};

const schemas = [
  breadcrumbSchema(breadcrumbs),
  articleSchema,
  ...(faqs && faqs.length > 0 ? [faqSchema(faqs)] : []),
];

const schemaString = JSON.stringify(schemas);

const publishedDate = new Date(datePublished);
const modifiedDate = dateModified ? new Date(dateModified) : null;
const dateLocale = lang === 'en' ? 'en-US' : 'it-IT';
const dateFormatter = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  schema={schemaString}
  lang={lang}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb navigation -->
    <nav aria-label="Breadcrumb" class="py-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center gap-1.5">
            {index > 0 && (
              <svg class="h-3.5 w-3.5 flex-shrink-0 text-gray-400 dark:text-gray-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            )}
            {index < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-brand transition-colors">
                {crumb.name}
              </a>
            ) : (
              <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">
                {crumb.name}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Article layout with TOC sidebar -->
    <div class="lg:grid lg:grid-cols-[1fr_minmax(0,48rem)_1fr] lg:gap-8 pb-16">
      <!-- Table of contents sidebar (desktop) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">
            {t('guide.toc', lang)}
          </h2>
          <nav aria-label={t('guide.tocAriaLabel', lang)}>
            <slot name="toc" />
          </nav>
        </div>
      </aside>

      <!-- Main article content -->
      <article class="min-w-0">
        <!-- Article header -->
        <header class="mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight">
            {title}
          </h1>

          <!-- Author byline and dates -->
          <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
              </svg>
              {t('guide.editorial', lang)} {SITE.name}
            </span>
            <time datetime={datePublished} class="flex items-center gap-1.5">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.75 2a.75.75 0 0 1 .75.75V4h7V2.75a.75.75 0 0 1 1.5 0V4h.25A2.75 2.75 0 0 1 18 6.75v8.5A2.75 2.75 0 0 1 15.25 18H4.75A2.75 2.75 0 0 1 2 15.25v-8.5A2.75 2.75 0 0 1 4.75 4H5V2.75A.75.75 0 0 1 5.75 2Zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75Z" clip-rule="evenodd" />
              </svg>
              {t('guide.publishedOn', lang)} {dateFormatter.format(publishedDate)}
            </time>
            {modifiedDate && (
              <time datetime={dateModified} class="flex items-center gap-1.5">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="m5.433 13.917 1.262-3.155A4 4 0 0 1 7.58 9.42l6.92-6.918a2.121 2.121 0 0 1 3 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 0 1-.65-.65Z" />
                  <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0 0 10 3H4.75A2.75 2.75 0 0 0 2 5.75v9.5A2.75 2.75 0 0 0 4.75 18h9.5A2.75 2.75 0 0 0 17 15.25V10a.75.75 0 0 0-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5Z" />
                </svg>
                {t('guide.updatedOn', lang)} {dateFormatter.format(modifiedDate)}
              </time>
            )}
          </div>
        </header>

        <!-- Article body -->
        <div class="prose prose-lg dark:prose-invert prose-headings:scroll-mt-20 prose-a:text-brand prose-a:no-underline hover:prose-a:underline max-w-none">
          <slot />
        </div>
      </article>

      <!-- Right spacer for centering -->
      <div class="hidden lg:block" aria-hidden="true"></div>
    </div>
  </div>
</Layout>
