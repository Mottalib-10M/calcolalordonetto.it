---
import Layout from './Layout.astro';
import { SITE } from '../config';
import { breadcrumbSchema, webAppSchema } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  calculatorName: string;
  breadcrumbs: { name: string; url: string }[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  calculatorName,
  breadcrumbs,
} = Astro.props;

const canonicalURL = canonical || Astro.url.href;

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webAppSchema(calculatorName, description, canonicalURL),
];

const schemaString = JSON.stringify(schemas);
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  schema={schemaString}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb navigation -->
    <nav aria-label="Breadcrumb" class="py-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
        {breadcrumbs.map((crumb, index) => (
          <li class="flex items-center gap-1.5">
            {index > 0 && (
              <svg class="h-3.5 w-3.5 flex-shrink-0 text-gray-400 dark:text-gray-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            )}
            {index < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-brand transition-colors">
                {crumb.name}
              </a>
            ) : (
              <span class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">
                {crumb.name}
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Anno fiscale stamp -->
    <div class="mb-6">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 dark:bg-green-900/30 px-3 py-1 text-xs font-medium text-green-700 dark:text-green-400 ring-1 ring-green-200 dark:ring-green-800">
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
        </svg>
        Aggiornato per l'anno fiscale {SITE.annoFiscale}
      </span>
    </div>

    <!-- Calculator slot -->
    <section>
      <slot />
    </section>

    <!-- Come si calcola explanation -->
    <section class="mt-12">
      <slot name="come-si-calcola" />
    </section>

    <!-- Valori anno corrente -->
    <section class="mt-12">
      <slot name="valori" />
    </section>

    <!-- FAQ accordion -->
    <section class="mt-12">
      <slot name="faq" />
    </section>

    <!-- Fonti section -->
    <aside class="mt-12 rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
        Fonti
      </h2>
      <ul class="mt-3 space-y-1.5 text-sm text-gray-600 dark:text-gray-400">
        <li>
          <a
            href="https://www.agenziaentrate.gov.it"
            target="_blank"
            rel="noopener noreferrer"
            class="underline hover:text-brand transition-colors"
          >
            Agenzia delle Entrate
          </a>
          : aliquote IRPEF, detrazioni, normativa fiscale
        </li>
        <li>
          <a
            href="https://www.inps.it"
            target="_blank"
            rel="noopener noreferrer"
            class="underline hover:text-brand transition-colors"
          >
            INPS
          </a>
          : aliquote contributive, massimali, prestazioni
        </li>
      </ul>
    </aside>

    <!-- Related calculators -->
    <section class="mt-12 mb-16">
      <slot name="correlati" />
    </section>
  </div>
</Layout>
