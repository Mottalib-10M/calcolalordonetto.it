---
import { SITE } from '../../config';

const calculatorLinks = [
  { name: 'Stipendio Netto', href: '/' },
  { name: 'Da Netto a Lordo', href: '/calcolo-stipendio-lordo/' },
  { name: 'Calcolo IRPEF', href: '/calcolo-irpef/' },
  { name: 'Busta Paga', href: '/calcolo-busta-paga/' },
  { name: 'Confronto Regioni', href: '/comparatore-regioni/' },
  { name: 'Tredicesima', href: '/calcolo-tredicesima/' },
  { name: 'TFR', href: '/calcolo-tfr/' },
  { name: 'Forfettari', href: '/calcolo-forfettari/' },
  { name: 'Impatriati', href: '/regime-impatriati-calcolatore/' },
  { name: 'Costo Aziendale', href: '/costo-aziendale/' },
  { name: 'Buonuscita', href: '/calcolo-buonuscita/' },
  { name: 'Dip. vs P.IVA', href: '/confronto-dipendente-piva/' },
  { name: 'ISEE', href: '/calcolo-isee/' },
  { name: 'Mutuo', href: '/calcolo-mutuo/' },
  { name: 'Pensione', href: '/calcolo-pensione/' },
  { name: 'FIRE', href: '/calcolo-fire/' },
  { name: 'Affitto vs Acquisto', href: '/confronto-affitto-acquisto/' },
  { name: 'Budget', href: '/calcolo-budget/' },
];

const resourceLinks = [
  { name: 'Guida allo Stipendio', href: '/guide/come-si-calcola-lo-stipendio-netto/' },
  { name: 'Scaglioni IRPEF 2026', href: '/guide/scaglioni-irpef-2026/' },
  { name: 'Cuneo Fiscale 2026', href: '/guide/cuneo-fiscale-2026/' },
  { name: 'Busta Paga', href: '/guide/busta-paga-come-leggerla/' },
  { name: 'Regime Forfettario', href: '/guide/regime-forfettario-2026/' },
  { name: 'Tutte le Guide', href: '/guide/' },
];

const legalLinks = [
  { name: 'Contatti', href: '/contatti/' },
  { name: 'Note Legali', href: '/note-legali/' },
  { name: 'Privacy Policy', href: '/privacy/' },
  { name: 'Cookie Policy', href: '/cookie-policy/' },
  { name: 'Termini di Servizio', href: '/termini/' },
];

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto">
  <!-- Red accent line -->
  <div class="h-1 bg-brand" aria-hidden="true"></div>

  <div class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- 4-column grid -->
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Column 1: Brand -->
        <div class="sm:col-span-2 lg:col-span-1">
          <a href="/" class="inline-flex items-center gap-1.5 text-lg font-bold tracking-tight">
            <span class="text-brand" aria-hidden="true">&euro;</span>
            <span class="text-charcoal dark:text-white">Calcola Lordo</span>
            <span class="text-brand">Netto</span>
          </a>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 max-w-xs">
            {SITE.tagline}
          </p>
          <p class="mt-4 text-xs text-gray-500 dark:text-gray-500">
            &copy; {currentYear} {SITE.name}
          </p>
        </div>

        <!-- Column 2: Calcolatori -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            Calcolatori
          </h3>
          <ul class="mt-4 space-y-2.5">
            {calculatorLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand dark:hover:text-brand transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Risorse -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            Risorse
          </h3>
          <ul class="mt-4 space-y-2.5">
            {resourceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand dark:hover:text-brand transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 4: Legale -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            Legale
          </h3>
          <ul class="mt-4 space-y-2.5">
            {legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand dark:hover:text-brand transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-xs text-gray-500 dark:text-gray-500 text-center leading-relaxed">
          I calcoli sono indicativi. Consulta un commercialista per la tua situazione specifica.
        </p>
        <p class="mt-2 text-xs text-gray-400 dark:text-gray-600 text-center leading-relaxed">
          Dati fiscali basati su normativa vigente {SITE.annoFiscale}. Fonti:
          <a href="https://www.agenziaentrate.gov.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">Agenzia delle Entrate</a>,
          <a href="https://www.inps.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">INPS</a>,
          <a href="https://www.istat.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">ISTAT</a>
        </p>
      </div>
    </div>
  </div>
</footer>
