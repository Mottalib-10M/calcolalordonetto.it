---
import { SITE } from '../../config';
import type { Lang } from '../../i18n/types';
import { t } from '../../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;

const calculatorLinks = lang === 'en'
  ? [
      { name: 'Net Salary', href: '/en/' },
      { name: 'Gross Salary', href: '/en/gross-salary-calculator/' },
      { name: 'IRPEF', href: '/en/irpef-tax-calculator/' },
      { name: 'Payslip', href: '/en/payslip-calculator/' },
      { name: 'Region Comparison', href: '/en/region-comparison/' },
      { name: '13th Month', href: '/en/thirteenth-month-calculator/' },
      { name: 'TFR', href: '/en/severance-pay-calculator/' },
      { name: 'Flat-Rate Regime', href: '/en/flat-rate-regime-calculator/' },
      { name: 'Impatriati', href: '/en/impatriati-tax-regime/' },
      { name: 'Employer Cost', href: '/en/employer-cost-calculator/' },
      { name: 'Severance', href: '/en/public-sector-severance/' },
      { name: 'Employee vs Freelancer', href: '/en/employee-vs-freelancer/' },
      { name: 'ISEE', href: '/en/isee-calculator/' },
      { name: 'Mortgage', href: '/en/mortgage-calculator/' },
      { name: 'Pension', href: '/en/pension-calculator/' },
      { name: 'FIRE', href: '/en/fire-calculator/' },
      { name: 'Rent vs Buy', href: '/en/rent-vs-buy/' },
      { name: 'Budget', href: '/en/budget-calculator/' },
      { name: 'Loan', href: '/en/loan-calculator/' },
      { name: 'Savings Plan', href: '/en/savings-plan-calculator/' },
      { name: 'Inflation', href: '/en/inflation-calculator/' },
      { name: t('header.allCalculators', 'en'), href: '/en/calculators/', bold: true },
    ]
  : [
      { name: 'Stipendio Netto', href: '/' },
      { name: 'Da Netto a Lordo', href: '/calcolo-stipendio-lordo/' },
      { name: 'Calcolo IRPEF', href: '/calcolo-irpef/' },
      { name: 'Busta Paga', href: '/calcolo-busta-paga/' },
      { name: 'Confronto Regioni', href: '/comparatore-regioni/' },
      { name: 'Tredicesima', href: '/calcolo-tredicesima/' },
      { name: 'TFR', href: '/calcolo-tfr/' },
      { name: 'Forfettari', href: '/calcolo-forfettari/' },
      { name: 'Impatriati', href: '/regime-impatriati-calcolatore/' },
      { name: 'Costo Aziendale', href: '/costo-aziendale/' },
      { name: 'Buonuscita', href: '/calcolo-buonuscita/' },
      { name: 'Dip. vs P.IVA', href: '/confronto-dipendente-piva/' },
      { name: 'ISEE', href: '/calcolo-isee/' },
      { name: 'Mutuo', href: '/calcolo-mutuo/' },
      { name: 'Pensione', href: '/calcolo-pensione/' },
      { name: 'FIRE', href: '/calcolo-fire/' },
      { name: 'Affitto vs Acquisto', href: '/confronto-affitto-acquisto/' },
      { name: 'Budget', href: '/calcolo-budget/' },
      { name: 'Prestito', href: '/calcolo-prestito/' },
      { name: 'Piano Accumulo', href: '/calcolo-piano-accumulo/' },
      { name: 'Inflazione', href: '/calcolo-inflazione/' },
      { name: 'Tutti i Calcolatori', href: '/calcolatori/', bold: true },
    ];

const resourceLinks = lang === 'en'
  ? [
      { name: 'Salary Guide', href: '/en/guides/how-to-calculate-net-salary/' },
      { name: 'IRPEF Brackets 2026', href: '/en/guides/irpef-tax-brackets-2026/' },
      { name: 'Tax Wedge 2026', href: '/en/guides/tax-wedge-2026/' },
      { name: 'Payslip Guide', href: '/en/guides/how-to-read-italian-payslip/' },
      { name: 'Flat-Rate Regime', href: '/en/guides/flat-rate-regime-2026/' },
      { name: 'Regional Surcharges', href: '/en/guides/regional-municipal-surcharges/' },
      { name: '13th & 14th Month', href: '/en/guides/thirteenth-fourteenth-month-pay/' },
      { name: 'TFR Severance', href: '/en/guides/how-tfr-severance-works/' },
      { name: 'Impatriati Regime', href: '/en/guides/impatriati-tax-regime/' },
      { name: t('footer.allGuides', 'en'), href: '/en/guides/', bold: true },
      { name: 'Free Widget', href: '/en/widget/' },
    ]
  : [
      { name: 'Guida allo Stipendio', href: '/guide/come-si-calcola-lo-stipendio-netto/' },
      { name: 'Scaglioni IRPEF 2026', href: '/guide/scaglioni-irpef-2026/' },
      { name: 'Cuneo Fiscale 2026', href: '/guide/cuneo-fiscale-2026/' },
      { name: 'Busta Paga', href: '/guide/busta-paga-come-leggerla/' },
      { name: 'Regime Forfettario', href: '/guide/regime-forfettario-2026/' },
      { name: 'Addizionali Regionali', href: '/guide/addizionali-regionali-comunali/' },
      { name: 'Tredicesima e 14esima', href: '/guide/tredicesima-quattordicesima/' },
      { name: 'TFR', href: '/guide/tfr-come-funziona/' },
      { name: 'Regime Impatriati', href: '/guide/regime-impatriati/' },
      { name: 'Tutte le Guide', href: '/guide/', bold: true },
      { name: 'Widget Gratuito', href: '/widget/' },
    ];

const legalLinks = lang === 'en'
  ? [
      { name: t('header.about', 'en'), href: '/en/about/' },
      { name: t('footer.contact', 'en'), href: '/en/contact/' },
      { name: t('footer.legalNotice', 'en'), href: '/en/legal-notice/' },
      { name: t('footer.privacy', 'en'), href: '/en/privacy/' },
      { name: t('footer.cookies', 'en'), href: '/en/cookie-policy/' },
      { name: t('footer.terms', 'en'), href: '/en/terms/' },
    ]
  : [
      { name: 'Chi Siamo', href: '/chi-siamo/' },
      { name: 'Contatti', href: '/contatti/' },
      { name: 'Note Legali', href: '/note-legali/' },
      { name: 'Privacy Policy', href: '/privacy/' },
      { name: 'Cookie Policy', href: '/cookie-policy/' },
      { name: 'Termini di Servizio', href: '/termini/' },
    ];

const currentYear = new Date().getFullYear();
const tagline = lang === 'en' ? SITE.taglineEn : SITE.tagline;
const homeHref = lang === 'en' ? '/en/' : '/';
---

<footer class="mt-auto">
  <!-- Red accent line -->
  <div class="h-1 bg-brand" aria-hidden="true"></div>

  <div class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <!-- 4-column grid -->
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Column 1: Brand -->
        <div class="sm:col-span-2 lg:col-span-1">
          <a href={homeHref} class="inline-flex items-center gap-1.5 text-lg font-bold tracking-tight">
            <span class="text-brand" aria-hidden="true">&euro;</span>
            <span class="text-charcoal dark:text-white">Calcola Lordo</span>
            <span class="text-brand">Netto</span>
          </a>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 max-w-xs">
            {tagline}
          </p>
          <p class="mt-4 text-xs text-gray-500 dark:text-gray-500">
            &copy; {currentYear} {SITE.name}
          </p>
        </div>

        <!-- Column 2: Calcolatori -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            {t('footer.calculators', lang)}
          </h3>
          <ul class="mt-4 space-y-2.5">
            {calculatorLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={`text-sm hover:text-brand dark:hover:text-brand transition-colors ${link.bold ? 'font-semibold text-brand' : 'text-gray-600 dark:text-gray-400'}`}
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Risorse -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            {t('footer.resources', lang)}
          </h3>
          <ul class="mt-4 space-y-2.5">
            {resourceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={`text-sm hover:text-brand dark:hover:text-brand transition-colors ${link.bold ? 'font-semibold text-brand' : 'text-gray-600 dark:text-gray-400'}`}
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 4: Legale -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
            {t('footer.legal', lang)}
          </h3>
          <ul class="mt-4 space-y-2.5">
            {legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-brand dark:hover:text-brand transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-200 dark:border-gray-800">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-xs text-gray-500 dark:text-gray-500 text-center leading-relaxed">
          {t('footer.disclaimer', lang)}
        </p>
        <p class="mt-2 text-xs text-gray-400 dark:text-gray-600 text-center leading-relaxed">
          {t('footer.dataSources', lang)} {SITE.annoFiscale}. {t('footer.sources', lang)}
          <a href="https://www.agenziaentrate.gov.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">Agenzia delle Entrate</a>,
          <a href="https://www.inps.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">INPS</a>,
          <a href="https://www.istat.it" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand transition-colors">ISTAT</a>
        </p>
      </div>
    </div>
  </div>
</footer>
