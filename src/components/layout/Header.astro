<script is:inline>
  (function () {
    // Mobile menu toggle
    var toggle = document.querySelector('[data-mobile-menu-toggle]');
    var menu = document.querySelector('[data-mobile-menu]');
    var iconMenu = document.querySelector('[data-icon-menu]');
    var iconClose = document.querySelector('[data-icon-close]');

    if (toggle && menu && iconMenu && iconClose) {
      toggle.addEventListener('click', function () {
        var isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden', isOpen);
        iconMenu.classList.toggle('hidden', !isOpen);
        iconMenu.classList.toggle('block', isOpen);
        iconClose.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('block', !isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    // Accordion: only one open at a time
    var accordions = document.querySelectorAll('[data-accordion]');
    accordions.forEach(function (details) {
      details.addEventListener('toggle', function () {
        if (details.open) {
          accordions.forEach(function (other) {
            if (other !== details && other.open) {
              other.removeAttribute('open');
            }
          });
        }
      });
    });

    // Rotate chevron on open
    var style = document.createElement('style');
    style.textContent = 'details[open] .details-open\\:rotate-180 { transform: rotate(180deg); }';
    document.head.appendChild(style);

    // Clamp dropdown panels within viewport on hover
    var groups = document.querySelectorAll('.group');
    groups.forEach(function (group) {
      var panel = group.querySelector('[data-dropdown-panel]');
      if (!panel) return;
      group.addEventListener('mouseenter', function () {
        // Reset any previous inline adjustments
        panel.style.left = '';
        panel.style.right = '';
        // Wait for panel to be rendered
        requestAnimationFrame(function () {
          var rect = panel.getBoundingClientRect();
          var vw = window.innerWidth;
          // If overflowing right edge
          if (rect.right > vw - 16) {
            var overflow = rect.right - vw + 16;
            panel.style.left = '';
            panel.style.right = '0px';
            // If right-aligned still overflows left
            var newRect = panel.getBoundingClientRect();
            if (newRect.left < 16) {
              panel.style.right = '';
              panel.style.left = (16 - rect.left) + 'px';
            }
          }
          // If overflowing left edge
          if (rect.left < 16) {
            panel.style.left = (16 - rect.left) + 'px';
            panel.style.right = '';
          }
        });
      });
      group.addEventListener('mouseleave', function () {
        panel.style.left = '';
        panel.style.right = '';
      });
    });
  })();
</script>
