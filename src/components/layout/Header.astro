---
import { SITE } from '../../config';
import type { Lang } from '../../i18n/types';
import { t } from '../../i18n/index';
import { getAlternatePath } from '../../i18n/routes';

interface Props {
  lang?: Lang;
}

const { lang = 'it' } = Astro.props;
const prefix = lang === 'en' ? '/en' : '';

// ── Dropdown 1: Stipendio ──────────────────────────────────────────────────
const flagshipCalc = lang === 'en'
  ? { name: t('nav.netSalary', 'en'), href: '/en/' }
  : { name: 'Calcola Stipendio Netto', href: '/' };

const salaryAnalysis = lang === 'en'
  ? [
      { name: t('nav.grossSalary', 'en'), href: '/en/gross-salary-calculator/', icon: 'arrows-right-left' },
      { name: t('nav.payslip', 'en'), href: '/en/payslip-calculator/', icon: 'document-text' },
      { name: t('nav.hourlyRate', 'en'), href: '/en/hourly-rate-calculator/', icon: 'clock' },
      { name: t('nav.regionComparison', 'en'), href: '/en/region-comparison/', icon: 'map' },
      { name: t('nav.thirteenth', 'en'), href: '/en/thirteenth-month-calculator/', icon: 'calendar' },
    ]
  : [
      { name: 'Da Netto a Lordo', href: '/calcolo-stipendio-lordo/', icon: 'arrows-right-left' },
      { name: 'Busta Paga', href: '/calcolo-busta-paga/', icon: 'document-text' },
      { name: 'Paga Oraria', href: '/calcolo-paga-oraria/', icon: 'clock' },
      { name: 'Confronto Regioni', href: '/comparatore-regioni/', icon: 'map' },
      { name: 'Tredicesima e 14esima', href: '/calcolo-tredicesima/', icon: 'calendar' },
    ];

const costAndSeverance = lang === 'en'
  ? [
      { name: t('nav.tfr', 'en'), href: '/en/severance-pay-calculator/', icon: 'building-library' },
      { name: t('nav.employerCost', 'en'), href: '/en/employer-cost-calculator/', icon: 'building-office' },
      { name: t('nav.leaveCalc', 'en'), href: '/en/leave-calculator/', icon: 'sun' },
      { name: t('nav.severance', 'en'), href: '/en/public-sector-severance/', icon: 'hand-raised' },
      { name: t('nav.familyDeductions', 'en'), href: '/en/family-tax-deductions/', icon: 'users' },
    ]
  : [
      { name: 'TFR', href: '/calcolo-tfr/', icon: 'building-library' },
      { name: 'Costo Aziendale', href: '/costo-aziendale/', icon: 'building-office' },
      { name: 'Ferie e Permessi', href: '/calcolo-ferie-permessi/', icon: 'sun' },
      { name: 'Buonuscita', href: '/calcolo-buonuscita/', icon: 'hand-raised' },
      { name: 'Detrazioni Familiari', href: '/calcolo-detrazioni-familiari/', icon: 'users' },
    ];

// ── Dropdown 2: Tasse & Regimi ─────────────────────────────────────────────
const taxCalculation = lang === 'en'
  ? [
      { name: t('nav.irpef', 'en'), href: '/en/irpef-tax-calculator/', icon: 'calculator' },
      { name: t('nav.isee', 'en'), href: '/en/isee-calculator/', icon: 'shield-check' },
      { name: t('nav.investmentTax', 'en'), href: '/en/investment-tax-calculator/', icon: 'chart-bar' },
      { name: t('nav.renovationBonus', 'en'), href: '/en/renovation-bonus-calculator/', icon: 'wrench' },
      { name: t('nav.propertyGains', 'en'), href: '/en/property-capital-gains/', icon: 'arrow-trending-up' },
    ]
  : [
      { name: 'Calcolo IRPEF', href: '/calcolo-irpef/', icon: 'calculator' },
      { name: 'ISEE', href: '/calcolo-isee/', icon: 'shield-check' },
      { name: 'Tassazione Investimenti', href: '/calcolo-tassazione-investimenti/', icon: 'chart-bar' },
      { name: 'Bonus Ristrutturazione', href: '/calcolo-bonus-ristrutturazione/', icon: 'wrench' },
      { name: 'Plusvalenza Immobiliare', href: '/calcolo-plusvalenza-immobiliare/', icon: 'arrow-trending-up' },
    ];

const taxRegimes = lang === 'en'
  ? [
      { name: t('nav.flatRate', 'en'), href: '/en/flat-rate-regime-calculator/', icon: 'building-storefront' },
      { name: t('nav.impatriati', 'en'), href: '/en/impatriati-tax-regime/', icon: 'globe' },
      { name: t('nav.employeeVsFreelancer', 'en'), href: '/en/employee-vs-freelancer/', icon: 'scale' },
    ]
  : [
      { name: 'Regime Forfettario', href: '/calcolo-forfettari/', icon: 'building-storefront' },
      { name: 'Regime Impatriati', href: '/regime-impatriati-calcolatore/', icon: 'globe' },
      { name: 'Dipendente vs P.IVA', href: '/confronto-dipendente-piva/', icon: 'scale' },
    ];

// ── Dropdown 3: Finanza Personale ──────────────────────────────────────────
const housingAndDebt = lang === 'en'
  ? [
      { name: t('nav.mortgage', 'en'), href: '/en/mortgage-calculator/', icon: 'home' },
      { name: t('nav.rentVsBuy', 'en'), href: '/en/rent-vs-buy/', icon: 'arrows-right-left' },
      { name: t('nav.loan', 'en'), href: '/en/loan-calculator/', icon: 'credit-card' },
      { name: t('nav.budget', 'en'), href: '/en/budget-calculator/', icon: 'chart-pie' },
    ]
  : [
      { name: 'Mutuo', href: '/calcolo-mutuo/', icon: 'home' },
      { name: 'Affitto vs Acquisto', href: '/confronto-affitto-acquisto/', icon: 'arrows-right-left' },
      { name: 'Prestito', href: '/calcolo-prestito/', icon: 'credit-card' },
      { name: 'Budget 50/30/20', href: '/calcolo-budget/', icon: 'chart-pie' },
    ];

const savingsAndFuture = lang === 'en'
  ? [
      { name: t('nav.pension', 'en'), href: '/en/pension-calculator/', icon: 'cloud' },
      { name: t('nav.fire', 'en'), href: '/en/fire-calculator/', icon: 'fire' },
      { name: t('nav.compoundInterest', 'en'), href: '/en/compound-interest-calculator/', icon: 'arrow-trending-up' },
      { name: t('nav.savingsPlan', 'en'), href: '/en/savings-plan-calculator/', icon: 'squares-plus' },
      { name: t('nav.inflation', 'en'), href: '/en/inflation-calculator/', icon: 'arrow-trending-down' },
    ]
  : [
      { name: 'Pensione', href: '/calcolo-pensione/', icon: 'cloud' },
      { name: 'FIRE', href: '/calcolo-fire/', icon: 'fire' },
      { name: 'Interesse Composto', href: '/calcolo-interesse-composto/', icon: 'arrow-trending-up' },
      { name: 'Piano Accumulo (PAC)', href: '/calcolo-piano-accumulo/', icon: 'squares-plus' },
      { name: 'Inflazione', href: '/calcolo-inflazione/', icon: 'arrow-trending-down' },
    ];

// ── Dropdown 4: Guide (unchanged structure) ────────────────────────────────
const guideSalaryTaxes = lang === 'en'
  ? [
      { name: 'Net Salary Guide', href: '/en/guides/how-to-calculate-net-salary/' },
      { name: 'IRPEF Brackets 2026', href: '/en/guides/irpef-tax-brackets-2026/' },
      { name: 'Regional & Municipal Surcharges', href: '/en/guides/regional-municipal-surcharges/' },
      { name: 'Tax Wedge 2026', href: '/en/guides/tax-wedge-2026/' },
      { name: 'How to Read a Payslip', href: '/en/guides/how-to-read-italian-payslip/' },
    ]
  : [
      { name: 'Guida allo Stipendio Netto', href: '/guide/come-si-calcola-lo-stipendio-netto/' },
      { name: 'Scaglioni IRPEF 2026', href: '/guide/scaglioni-irpef-2026/' },
      { name: 'Addizionali Regionali e Comunali', href: '/guide/addizionali-regionali-comunali/' },
      { name: 'Cuneo Fiscale 2026', href: '/guide/cuneo-fiscale-2026/' },
      { name: 'Busta Paga: Come Leggerla', href: '/guide/busta-paga-come-leggerla/' },
    ];

const guideContractsRegimes = lang === 'en'
  ? [
      { name: '13th & 14th Month Pay', href: '/en/guides/thirteenth-fourteenth-month-pay/' },
      { name: 'How TFR Works', href: '/en/guides/how-tfr-severance-works/' },
      { name: 'Impatriati Regime', href: '/en/guides/impatriati-tax-regime/' },
      { name: 'Flat-Rate Regime 2026', href: '/en/guides/flat-rate-regime-2026/' },
    ]
  : [
      { name: 'Tredicesima e Quattordicesima', href: '/guide/tredicesima-quattordicesima/' },
      { name: 'TFR: Come Funziona', href: '/guide/tfr-come-funziona/' },
      { name: 'Regime Impatriati', href: '/guide/regime-impatriati/' },
      { name: 'Regime Forfettario 2026', href: '/guide/regime-forfettario-2026/' },
    ];

const allCalculatorsHref = lang === 'en' ? '/en/calculators/' : '/calcolatori/';
const allGuidesHref = lang === 'en' ? '/en/guides/' : '/guide/';

// Language switcher
const currentPath = Astro.url.pathname;
const switchPath = getAlternatePath(currentPath, lang);
const switchLang = lang === 'en' ? 'it' : 'en';
const switchLabel = t('site.langSwitchLabel', lang);
const homeHref = lang === 'en' ? '/en/' : '/';

// ── Icon helper — Heroicons outline, h-4 w-4 ──────────────────────────────
