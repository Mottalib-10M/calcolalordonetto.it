---
/**
 * FAQ Accordion component using native HTML <details>/<summary>.
 * No JavaScript needed — accessible, lightweight, works everywhere.
 */

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  titolo?: string;
}

const { faqs, titolo = 'Domande Frequenti' } = Astro.props;
---

<div class="space-y-3">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">{titolo}</h2>
  {faqs.map((faq, index) => (
    <details
      class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 transition-shadow hover:shadow-sm"
    >
      <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left font-medium text-gray-900 dark:text-white [&::-webkit-details-marker]:hidden list-none">
        <span>{faq.question}</span>
        <svg
          class="h-5 w-5 flex-shrink-0 text-gray-500 transition-transform group-open:rotate-180"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
            clip-rule="evenodd"
          />
        </svg>
      </summary>
      <div class="px-5 pb-5 text-gray-600 dark:text-gray-400 leading-relaxed">
        <Fragment set:html={faq.answer} />
      </div>
    </details>
  ))}
</div>
